<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             x:Class="Diarion.Views.ProfilePage"
             x:DataType="viewmodels:ProfileViewModel"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource Theme_Earth_Midnight}">

    <ScrollView>
        <VerticalStackLayout Padding="24,18,24,32" Spacing="20">
            
            <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,8">
                <!-- Hamburger Menu Button -->
                <Grid Grid.Column="0" Padding="10,0">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenMenuCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Text="≡" FontSize="32" 
                           InputTransparent="True"
                           TextColor="{DynamicResource Theme_Midnight_Snow}" 
                           VerticalOptions="Center" HorizontalOptions="Start" />
                </Grid>
                
                <!-- Заголовок -->
                <Label Grid.Column="1" Text="{Binding Title}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" Margin="-40,0,0,0" />
            </Grid>
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{DynamicResource Theme_Ocean_Dust}" />

            <!-- Особиста інформація -->
            <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                    BackgroundColor="{DynamicResource Theme_Snow_Black}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static localization:AppResources.GeneralInfoLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                    
                    <Grid ColumnDefinitions="80, *" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="{x:Static localization:AppResources.NameLabel}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        <Entry Grid.Column="1" Text="{Binding Profile.Name}" Placeholder="{x:Static localization:AppResources.NamePlaceholder}" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                    </Grid>
                    
                    <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />
                    
                    <Grid ColumnDefinitions="50, *, 40, 60" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="{x:Static localization:AppResources.GenderLabel}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        <Picker Grid.Column="1" ItemsSource="{Binding GenderList}" ItemDisplayBinding="{Binding DisplayName}" SelectedItem="{Binding SelectedGenderItem}" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                        
                        <Label Grid.Column="2" Text="{x:Static localization:AppResources.AgeLabel}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" HorizontalTextAlignment="End" />
                        <Entry Grid.Column="3" Text="{Binding Profile.Age}" Keyboard="Numeric" Placeholder="0" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" HorizontalTextAlignment="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />
                    
                    <Grid ColumnDefinitions="80, *, 80, *" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="{x:Static localization:AppResources.WeightLabel}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        <Entry Grid.Column="1" Text="{Binding Profile.Weight}" Keyboard="Numeric" Placeholder="0.0" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                        
                        <Label Grid.Column="2" Text="{x:Static localization:AppResources.HeightLabel}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" HorizontalTextAlignment="End" />
                        <Entry Grid.Column="3" Text="{Binding Profile.Height}" Keyboard="Numeric" Placeholder="0" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Налаштування завдань -->
            <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                    BackgroundColor="{DynamicResource Theme_Snow_Black}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static localization:AppResources.TaskSettingsTitle}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                    
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                        <CheckBox Grid.Column="0" IsChecked="{Binding Profile.AutoMigrateUncompletedTasksEnabled}" Color="{DynamicResource Theme_Coral}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{x:Static localization:AppResources.AutoMigrateTasksLabel}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Менструальний календар (Menstrual Tracker) -->
            <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                    BackgroundColor="{DynamicResource Theme_Snow_Black}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static localization:AppResources.MenstrualTrackingTitle}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Coral}" />
                    
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                        <CheckBox Grid.Column="0" IsChecked="{Binding Profile.IsMenstrualTrackingEnabled}" Color="{DynamicResource Theme_Coral}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{x:Static localization:AppResources.EnableTrackingLabel}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                    </Grid>

                    <VerticalStackLayout Spacing="16" IsVisible="{Binding Profile.IsMenstrualTrackingEnabled}">
                        <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />
                        
                        <Grid ColumnDefinitions="*, 80" ColumnSpacing="12">
                            <Label Grid.Column="0" Text="{x:Static localization:AppResources.CycleLengthLabel}" VerticalOptions="Center" FontSize="13" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                            <Entry Grid.Column="1" Text="{Binding Profile.CycleLength}" Keyboard="Numeric" BackgroundColor="Transparent" FontSize="14" HorizontalTextAlignment="Center" />
                        </Grid>
                        
                        <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />
                        
                        <Grid ColumnDefinitions="*, 80" ColumnSpacing="12">
                            <Label Grid.Column="0" Text="{x:Static localization:AppResources.PeriodLengthLabel}" VerticalOptions="Center" FontSize="13" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                            <Entry Grid.Column="1" Text="{Binding Profile.PeriodLength}" Keyboard="Numeric" BackgroundColor="Transparent" FontSize="14" HorizontalTextAlignment="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />
                        
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{x:Static localization:AppResources.LastPeriodDateLabel}" FontSize="13" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                            <DatePicker Date="{Binding Profile.LastPeriodStartDate, TargetNullValue={x:Static sys:DateTime.Today}}" TextColor="{DynamicResource Theme_Midnight_Snow}" BackgroundColor="Transparent" FontSize="14" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Безпека (Security) -->
            <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                    BackgroundColor="{DynamicResource Theme_Snow_Black}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static localization:AppResources.SecurityLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Coral}" />
                    
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                        <Switch Grid.Column="0" IsToggled="{Binding IsBiometricAuthEnabled}" OnColor="{DynamicResource Theme_Ocean_Ocean}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{x:Static localization:AppResources.EnableBiometricsLabel}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Backup & Restore -->
            <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                    BackgroundColor="{DynamicResource Theme_Snow_Black}"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static localization:AppResources.BackupTitle}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                    
                    <Label Text="{x:Static localization:AppResources.BackupDescription}" FontSize="13" TextColor="{DynamicResource Theme_Ocean_Dust}" Margin="0,0,0,8" />
                    
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <Button Grid.Column="0" Text="{x:Static localization:AppResources.BackupExportButton}"
                                Command="{Binding ExportBackupCommand}"
                                BackgroundColor="Transparent"
                                BorderColor="{DynamicResource Theme_Ocean_Ocean}"
                                BorderWidth="1"
                                TextColor="{DynamicResource Theme_Midnight_Snow}"
                                CornerRadius="12"
                                HeightRequest="44" />
                        
                        <Button Grid.Column="1" Text="{x:Static localization:AppResources.BackupImportButton}"
                                Command="{Binding ImportBackupCommand}"
                                BackgroundColor="Transparent"
                                BorderColor="{DynamicResource Theme_Amber}"
                                BorderWidth="1"
                                TextColor="{DynamicResource Theme_Midnight_Snow}"
                                CornerRadius="12"
                                HeightRequest="44" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <Button Text="{x:Static localization:AppResources.SaveProfileButton}"
                    Command="{Binding SaveProfileCommand}"
                    BackgroundColor="{DynamicResource Theme_Ocean_Ocean}"
                    TextColor="{DynamicResource Theme_Snow}"
                    CornerRadius="12"
                    HeightRequest="48"
                    Margin="0,10,0,10" />

            <!-- Delete All Data Button -->
            <Button Text="{x:Static localization:AppResources.ClearAllDataButton}"
                    Command="{Binding ClearAllDataCommand}"
                    BackgroundColor="Transparent"
                    BorderColor="{DynamicResource Theme_Coral}"
                    BorderWidth="1"
                    TextColor="{DynamicResource Theme_Coral}"
                    CornerRadius="12"
                    HeightRequest="48"
                    Margin="0,0,0,20" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
