<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:viewModels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             x:Class="Diarion.Views.HappyMomentsPage"
             x:Name="RootPage"
             x:DataType="viewModels:HappyMomentsViewModel"
             Shell.PresentationMode="ModalAnimated"
             Title="{localization:Translate Key=HappyMomentsTitle}"
             BackgroundColor="{AppThemeBinding Light={StaticResource Earth}, Dark={StaticResource Midnight}}">

    <Grid RowDefinitions="Auto,*">
        <Grid Padding="24,18,24,6" ColumnDefinitions="Auto,*,Auto">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent" VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseTapped" />
                </Grid.GestureRecognizers>
                <Label Text="✕" FontSize="22" InputTransparent="True" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
            </Grid>

            <VerticalStackLayout Grid.Column="1" Spacing="4">
                <Label Text="{localization:Translate Key=HappyMomentsTitle}" FontSize="24" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                <Label Text="{localization:Translate Key=HappyMomentsSubtitle}" FontSize="12" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="2"
                               WidthRequest="28"
                               HeightRequest="28"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Berry}"
                               VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,10,24,32" Spacing="18">
                <FlexLayout BindableLayout.ItemsSource="{Binding MomentSlots}"
                            Direction="Row"
                            Wrap="Wrap"
                            JustifyContent="SpaceBetween"
                            AlignItems="Start">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:HappyMomentSlotItemViewModel">
                            <Border WidthRequest="96"
                                    HeightRequest="120"
                                    Padding="6"
                                    Margin="0,0,0,16"
                                            StrokeThickness="1"
                                            Stroke="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Midnight}}"
                                            StrokeShape="RoundRectangle 8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.SelectSlotCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Stroke" Value="{StaticResource Berry}" />
                                                <Setter Property="StrokeThickness" Value="2" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Grid RowDefinitions="*,Auto">
                                            <!-- Polaroid photo area -->
                                            <Border StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light=#1AA87C8E, Dark=#268FA083}">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsEmpty}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#14A87C8E, Dark=#1AFFFFFF}" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Grid>
                                                    <!-- Empty state icon -->
                                                    <Label Text="+"
                                                           IsVisible="{Binding IsEmpty}"
                                                           FontSize="36"
                                                           FontAttributes="Bold"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center"
                                                           InputTransparent="True"
                                                           TextColor="{StaticResource Berry}" />
                                                    
                                                    <!-- Filled state content -->
                                                    <VerticalStackLayout IsVisible="{Binding IsFilled}"
                                                                         Padding="4"
                                                                         Spacing="2"
                                                                         VerticalOptions="Center">
                                                        <Label Text="✦"
                                                               FontSize="24"
                                                               HorizontalOptions="Center"
                                                               TextColor="{StaticResource Berry}" />
                                                        <Label Text="{Binding MomentTitle}"
                                                               FontSize="10"
                                                               FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center"
                                                               LineBreakMode="WordWrap"
                                                               MaxLines="3"
                                                               InputTransparent="True"
                                                               TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>

                                            <!-- Polaroid bottom caption -->
                                            <VerticalStackLayout Grid.Row="1" Spacing="2" Padding="2,6,2,0">
                                                <Label Text="{Binding DateText}"
                                                       IsVisible="{Binding IsFilled}"
                                                       FontSize="9"
                                                       FontAttributes="Bold"
                                                       HorizontalTextAlignment="Center"
                                                       InputTransparent="True"
                                                       TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Dust}}" />
                                                <Label Text="{Binding SlotCaption}"
                                                       IsVisible="{Binding IsEmpty}"
                                                       FontSize="9"
                                                       HorizontalTextAlignment="Center"
                                                       InputTransparent="True"
                                                       TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                <Border StrokeShape="RoundRectangle 24"
                        StrokeThickness="1"
                        Stroke="{StaticResource Berry}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}"
                        Padding="18"
                        IsVisible="{Binding IsAddMomentFormVisible}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="42"
                                    HeightRequest="42"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource Berry}">
                                <Label Text="✦"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="{StaticResource Snow}" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="{localization:Translate Key=HappyMomentsFormTitle}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Label Text="{Binding SelectedEmptySlot.SlotCaption}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label Text="{localization:Translate Key=HappyMomentsTitleLabel}"
                               FontSize="12"
                               FontAttributes="Bold"
                               CharacterSpacing="1.2"
                               TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                        <Entry Text="{Binding NewMomentTitle}"
                               Placeholder="{localization:Translate Key=HappyMomentsTitlePlaceholder}"
                               ClearButtonVisibility="WhileEditing"
                               TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}" />

                        <Label Text="{localization:Translate Key=HappyMomentsDateLabel}"
                               FontSize="12"
                               FontAttributes="Bold"
                               CharacterSpacing="1.2"
                               TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                        <DatePicker Date="{Binding NewMomentDate}"
                                    MaximumDate="{Binding MaxMomentDate}"
                                    TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />

                        <Label Text="{Binding ValidationMessage}"
                               IsVisible="{Binding HasValidationMessage}"
                               FontSize="12"
                               TextColor="{StaticResource Coral}" />

                        <Button Text="{localization:Translate Key=HappyMomentsSaveButton}"
                                Command="{Binding SaveSelectedMomentCommand}"
                                CornerRadius="18"
                                Padding="18,12"
                                BackgroundColor="{StaticResource Berry}"
                                TextColor="{StaticResource Snow}"
                                FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>