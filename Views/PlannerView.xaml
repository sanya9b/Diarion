<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             x:Class="Diarion.Views.PlannerView"
             x:DataType="viewmodels:MainViewModel">
             
    <VerticalStackLayout Padding="20,2,20,20" Spacing="10">
        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
            <Label Grid.Column="0" Text="{x:Static localization:AppResources.TodoListLabel}" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
            <Border Grid.Column="1" Padding="10,4" StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}">
                <Label Text="{Binding SelectedDateDayName}" FontSize="11" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
            </Border>
        </Grid>

        <CollectionView ItemsSource="{Binding Todos}" ItemSizingStrategy="MeasureFirstItem">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="32" Spacing="12">
                    <Label Text="{x:Static localization:AppResources.NoTasks}" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TodoItem">
                    <Border Margin="0,4" StrokeShape="RoundRectangle 24" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=GoToTodoDetailsCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource Midnight}" Offset="0,4" Radius="8" Opacity="{AppThemeBinding Light=0.05, Dark=0.2}" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto" Padding="12,10" ColumnSpacing="10" VerticalOptions="Center">
                            <Border Grid.Column="0" WidthRequest="28" HeightRequest="28" StrokeShape="RoundRectangle 8"
                                    StrokeThickness="2" VerticalOptions="Center">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=ToggleTodoCompletionCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Label Text="✓" InputTransparent="True" TextColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Midnight}}" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsCompleted}" />
                            </Border>

                            <Label Grid.Column="1" Text="{Binding TaskDescription}" InputTransparent="True" FontSize="14" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Border Grid.Column="2" StrokeShape="RoundRectangle 6" Padding="6,2" VerticalOptions="Center">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="Low">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Earth}, Dark={StaticResource Black}}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="Medium">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Midnight}}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="High">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Ocean}}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label FontSize="10" FontAttributes="Bold" InputTransparent="True">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Priority}" Value="Low">
                                            <Setter Property="Text" Value="{x:Static localization:AppResources.PriorityLow}" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Priority}" Value="Medium">
                                            <Setter Property="Text" Value="{x:Static localization:AppResources.PriorityMedium}" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Priority}" Value="High">
                                            <Setter Property="Text" Value="{x:Static localization:AppResources.PriorityHigh}" />
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Midnight}}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>

                            <ImageButton Grid.Column="3" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" BackgroundColor="Transparent"
                                         Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=DeleteTodoCommand}"
                                         CommandParameter="{Binding .}">
                                <ImageButton.Source>
                                    <FontImageSource FontFamily="OpenSansRegular" Glyph="✕" Color="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Dust}}" Size="16" />
                                </ImageButton.Source>
                            </ImageButton>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>
