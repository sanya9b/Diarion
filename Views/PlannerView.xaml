<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             x:Class="Diarion.Views.PlannerView"
             x:DataType="viewmodels:MainViewModel">
             
    <Grid RowDefinitions="Auto, *" Padding="20,2,20,20" RowSpacing="10">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" VerticalOptions="Center" ColumnSpacing="12">
            <Label Grid.Column="0" Text="{x:Static localization:AppResources.TodoListLabel}" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
            
            <Grid Grid.Column="1" VerticalOptions="Center" HorizontalOptions="End">
                <Border StrokeShape="RoundRectangle 8"
                        WidthRequest="36" HeightRequest="28"
                        BackgroundColor="{DynamicResource Theme_Ocean_Ocean}"
                        StrokeThickness="0">
                    <Label Text="+"
                           TextColor="{DynamicResource Theme_Snow}"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TranslationY="-1" />
                </Border>
                <!-- ABSOLUTE HITBOX -->
                <BoxView BackgroundColor="Transparent" HorizontalOptions="Fill" VerticalOptions="Fill">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToNewTodoCommand}" />
                    </BoxView.GestureRecognizers>
                </BoxView>
            </Grid>
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Todos}" ItemSizingStrategy="MeasureFirstItem">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="32" Spacing="12">
                    <Label Text="{x:Static localization:AppResources.NoTasks}" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TodoItem">
                    <Border Margin="0,4" StrokeShape="RoundRectangle 24" StrokeThickness="0"
                            BackgroundColor="{DynamicResource Theme_Snow_Black}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=GoToTodoDetailsCommand}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,4" Radius="8" Opacity="{AppThemeBinding Light=0.05, Dark=0.2}" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto" Padding="12,10" ColumnSpacing="10" VerticalOptions="Center">
                            <Border Grid.Column="0" WidthRequest="28" HeightRequest="28" StrokeShape="RoundRectangle 8"
                                    StrokeThickness="2" VerticalOptions="Center">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                        <Setter Property="Stroke" Value="{DynamicResource Theme_Ocean_Dust}" />
                                    </DataTrigger>
                                    <MultiTrigger TargetType="Border">
                                        <MultiTrigger.Conditions>
                                            <BindingCondition Binding="{Binding IsCompleted}" Value="True" />
                                            <BindingCondition Binding="{Binding Priority}" Value="Low" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Sage}" />
                                        <Setter Property="Stroke" Value="{DynamicResource Theme_Sage}" />
                                    </MultiTrigger>
                                    <MultiTrigger TargetType="Border">
                                        <MultiTrigger.Conditions>
                                            <BindingCondition Binding="{Binding IsCompleted}" Value="True" />
                                            <BindingCondition Binding="{Binding Priority}" Value="Medium" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Amber}" />
                                        <Setter Property="Stroke" Value="{DynamicResource Theme_Amber}" />
                                    </MultiTrigger>
                                    <MultiTrigger TargetType="Border">
                                        <MultiTrigger.Conditions>
                                            <BindingCondition Binding="{Binding IsCompleted}" Value="True" />
                                            <BindingCondition Binding="{Binding Priority}" Value="High" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Coral}" />
                                        <Setter Property="Stroke" Value="{DynamicResource Theme_Coral}" />
                                    </MultiTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=ToggleTodoCompletionCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Label Text="✓" InputTransparent="True" TextColor="{DynamicResource Theme_Snow_Midnight}" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsCompleted}" />
                            </Border>

                            <Label Grid.Column="1" Text="{Binding TaskDescription}" InputTransparent="True" FontSize="14" VerticalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                        <Setter Property="TextColor" Value="{DynamicResource Theme_Ocean_Dust}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Border Grid.Column="2" StrokeShape="RoundRectangle 6" Padding="6,2" VerticalOptions="Center">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="Low">
                                        <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Sage}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="Medium">
                                        <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Amber}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding Priority}" Value="High">
                                        <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Coral}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label FontSize="10" FontAttributes="Bold" InputTransparent="True">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Priority}" Value="Low">
                                            <Setter Property="Text" Value="{x:Static localization:AppResources.PriorityLow}" />
                                            <Setter Property="TextColor" Value="{DynamicResource Theme_Snow}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Priority}" Value="Medium">
                                            <Setter Property="Text" Value="{x:Static localization:AppResources.PriorityMedium}" />
                                            <Setter Property="TextColor" Value="{DynamicResource Theme_Snow}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Priority}" Value="High">
                                            <Setter Property="Text" Value="{x:Static localization:AppResources.PriorityHigh}" />
                                            <Setter Property="TextColor" Value="{DynamicResource Theme_Snow}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>

                            <ImageButton Grid.Column="3" WidthRequest="20" HeightRequest="20" VerticalOptions="Center" BackgroundColor="Transparent"
                                         Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=DeleteTodoCommand}"
                                         CommandParameter="{Binding .}">
                                <ImageButton.Source>
                                    <FontImageSource FontFamily="OpenSansRegular" Glyph="✕" Color="{DynamicResource Theme_Midnight_Dust}" Size="16" />
                                </ImageButton.Source>
                            </ImageButton>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>
