<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:viewModels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Diarion.Views.WishlistPage"
             x:Name="RootPage"
             x:DataType="viewModels:WishlistViewModel"
             Shell.PresentationMode="ModalAnimated"
             Title="{localization:Translate Key=WishlistTitle}"
             BackgroundColor="{DynamicResource Theme_Earth_Midnight}">

    <Grid RowDefinitions="Auto,*">
        <Grid Padding="24,18,24,6" ColumnDefinitions="Auto,*,Auto">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent" VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseTapped" />
                </Grid.GestureRecognizers>
                <Label Text="✕" FontSize="22" InputTransparent="True" TextColor="{DynamicResource Theme_Midnight_Snow}" />
            </Grid>

            <VerticalStackLayout Grid.Column="1" Spacing="4">
                <Label Text="{localization:Translate Key=WishlistTitle}" FontSize="24" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="2"
                               WidthRequest="28"
                               HeightRequest="28"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{DynamicResource Theme_Berry}"
                               VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,10,24,32" Spacing="18">
                
                <!-- Кнопка додавання -->
                <Border Padding="16"
                        StrokeThickness="1"
                        Stroke="{DynamicResource Theme_Berry}"
                        BackgroundColor="{DynamicResource Theme_Snow_Midnight}"
                        StrokeShape="RoundRectangle 16"
                        HorizontalOptions="Fill">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAddFormCommand}" />
                    </Border.GestureRecognizers>
                    <Border.Shadow>
                        <Shadow Brush="{DynamicResource Theme_Berry}" Offset="0,4" Radius="8" Opacity="0.15" />
                    </Border.Shadow>
                    
                    <Grid ColumnDefinitions="Auto, *">
                        <Label Grid.Column="0" Text="+" FontSize="24" FontAttributes="Bold" TextColor="{DynamicResource Theme_Berry}" VerticalOptions="Center" Margin="0,0,12,0"/>
                        <Label Grid.Column="1" Text="{localization:Translate Key=AddTodoButton}" FontSize="16" FontAttributes="Bold" TextColor="{DynamicResource Theme_Midnight_Snow}" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Список записів -->
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Entries}" Spacing="12" Margin="0,12,0,0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:WishlistEntry">
                            <Border Padding="12,10"
                                    StrokeThickness="1"
                                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                                    BackgroundColor="{DynamicResource Theme_Snow_Midnight}"
                                    StrokeShape="RoundRectangle 14">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.OpenAddFormCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="Opacity" Value="0.6" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12" VerticalOptions="Center">
                                    <!-- Checkbox for completion -->
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}" VerticalOptions="Center" Scale="0.8" Margin="-8,0,-4,0">
                                        <CheckBox.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.ToggleCompletedCommand}" CommandParameter="{Binding .}" />
                                        </CheckBox.GestureRecognizers>
                                    </CheckBox>

                                    <!-- Want Text -->
                                    <Label Grid.Column="1" Text="{Binding WantText}" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" VerticalOptions="Center" LineBreakMode="TailTruncation" IsVisible="{Binding WantText, Converter={toolkit:IsStringNotNullOrWhiteSpaceConverter}}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="TextColor" Value="{DynamicResource Theme_Ocean_Dust}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    
                                    <!-- Date -->
                                    <Label Grid.Column="2" Text="{Binding Date, StringFormat='{0:dd.MM.yyyy}'}" FontSize="11" FontAttributes="Bold" TextColor="{DynamicResource Theme_Ocean_Dust}" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Popup Overlay для додавання/редагування -->
        <Grid Grid.RowSpan="2"
              BackgroundColor="{DynamicResource Theme_Val_99000000_B3000000}"
              IsVisible="{Binding IsAddFormVisible}"
              InputTransparent="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseFormCommand}" />
            </Grid.GestureRecognizers>

            <Border StrokeShape="RoundRectangle 24"
                    StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Berry}"
                    BackgroundColor="{DynamicResource Theme_Snow_Midnight}"
                    Padding="24"
                    Margin="24"
                    VerticalOptions="Center">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,4" Radius="10" Opacity="0.2" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <!-- Перехоплюємо тап, щоб не закривати попап при кліку на нього -->
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <Label Grid.Column="0" Text="{localization:Translate Key=WishlistTitle}" FontSize="18" FontAttributes="Bold" TextColor="{DynamicResource Theme_Midnight_Snow}" VerticalOptions="Center"/>
                        <!-- Close Button -->
                        <Grid Grid.Column="1" VerticalOptions="Start" Padding="8,0,0,8">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseFormCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Text="✕" FontSize="20" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                        </Grid>
                    </Grid>

                    <Editor Text="{Binding NewWantText}" AutoSize="TextChanges" BackgroundColor="Transparent" TextColor="{DynamicResource Theme_Midnight_Snow}" FontSize="15" MinimumHeightRequest="40" Placeholder="{localization:Translate Key=WantLabel}" PlaceholderColor="{DynamicResource Theme_Ocean_Dust}" />

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Grid.Column="0"
                                Text="{localization:Translate Key=DeleteButton}"
                                Command="{Binding DeleteCurrentEntryCommand}"
                                IsVisible="{Binding IsEditing}"
                                CornerRadius="12"
                                Padding="16,12"
                                BackgroundColor="Transparent"
                                BorderColor="{DynamicResource Theme_Coral}"
                                BorderWidth="1"
                                TextColor="{DynamicResource Theme_Coral}"
                                FontAttributes="Bold" />

                        <Button Grid.Column="1"
                                Text="{localization:Translate Key=SaveButton}"
                                Command="{Binding SaveEntryCommand}"
                                IsVisible="{Binding IsEditing}"
                                CornerRadius="12"
                                Padding="16,12"
                                BackgroundColor="{DynamicResource Theme_Berry}"
                                TextColor="{DynamicResource Theme_Snow}"
                                FontAttributes="Bold" />

                        <Button Grid.Column="0" Grid.ColumnSpan="2"
                                Text="{localization:Translate Key=SaveButton}"
                                Command="{Binding SaveEntryCommand}"
                                IsVisible="{Binding IsEditing, Converter={toolkit:InvertedBoolConverter}}"
                                CornerRadius="12"
                                Padding="16,12"
                                BackgroundColor="{DynamicResource Theme_Berry}"
                                TextColor="{DynamicResource Theme_Snow}"
                                FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>