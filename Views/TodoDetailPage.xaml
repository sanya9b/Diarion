<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             x:Class="Diarion.Views.TodoDetailPage"
             x:DataType="viewmodels:TodoDetailViewModel"
             Shell.PresentationMode="ModalAnimated"
             BackgroundColor="{DynamicResource Theme_Earth_Midnight}"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">
        <Grid Padding="24,18,24,6" ColumnDefinitions="Auto,*,Auto">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent" VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="✕" FontSize="22" InputTransparent="True" TextColor="{DynamicResource Theme_Midnight_Snow}" />
            </Grid>

            <VerticalStackLayout Grid.Column="1" Spacing="2">
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                <Label Text="{x:Static localization:AppResources.TaskDateLabel}" FontSize="10" CharacterSpacing="1.6" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <Label Text="{Binding TargetDateDisplay}" FontSize="14" FontAttributes="Italic" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="2"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               WidthRequest="24"
                               HeightRequest="24"
                               Color="{DynamicResource Theme_Ocean_Dust}" />
        </Grid>

        <Grid Grid.Row="1" Padding="24,10,24,24" RowSpacing="14" RowDefinitions="Auto, Auto">
            <Border Grid.Row="0" StrokeShape="RoundRectangle 24"
                    StrokeThickness="1"
                        Stroke="{DynamicResource Theme_Dust_Ocean}"
                        BackgroundColor="{DynamicResource Theme_Snow_Black}"
                        Padding="18,18">
                    <Border.Shadow>
                        <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.TaskDescriptionLabel}" FontAttributes="Bold" FontSize="10" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                            <Entry Text="{Binding TaskDescription}"
                                   Placeholder="{x:Static localization:AppResources.AddTodoPlaceholder}"
                                   PlaceholderColor="{DynamicResource Theme_Ocean_Dust}"
                                   TextColor="{DynamicResource Theme_Midnight_Snow}"
                                   BackgroundColor="Transparent"
                                   HeightRequest="42" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox IsChecked="{Binding IsCompleted}"
                                      VerticalOptions="Center">
                                <CheckBox.Triggers>
                                    <DataTrigger TargetType="CheckBox" Binding="{Binding SelectedPriority}" Value="Low">
                                        <Setter Property="Color" Value="{DynamicResource Theme_Sage}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="CheckBox" Binding="{Binding SelectedPriority}" Value="Medium">
                                        <Setter Property="Color" Value="{DynamicResource Theme_Amber}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="CheckBox" Binding="{Binding SelectedPriority}" Value="High">
                                        <Setter Property="Color" Value="{DynamicResource Theme_Coral}" />
                                    </DataTrigger>
                                </CheckBox.Triggers>
                            </CheckBox>
                            <Label Grid.Column="1" Text="{x:Static localization:AppResources.TaskCompletedLabel}" VerticalOptions="Center" FontSize="15" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />

                        <!-- Options section -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox IsChecked="{Binding HasTime}" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static localization:AppResources.AddTimeLabel}" VerticalOptions="Center" FontSize="15" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="12" IsVisible="{Binding HasTime}">
                            <Label Grid.Column="0" Text="{x:Static localization:AppResources.TimeLabel}" VerticalOptions="Center" FontSize="12" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                            <TimePicker Grid.Column="1" Time="{Binding TargetTime}" Format="HH:mm" TextColor="{DynamicResource Theme_Midnight_Snow}" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox IsChecked="{Binding IsDailyRepeat}" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static localization:AppResources.DailyRepeatLabel}" VerticalOptions="Center" FontSize="15" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <CheckBox IsChecked="{Binding HasReminder}" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{x:Static localization:AppResources.ReminderLabel}" VerticalOptions="Center" FontSize="15" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />

                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.TaskPriorityLabel}" FontAttributes="Bold" FontSize="10" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                            
                            <CollectionView ItemsSource="{Binding PrioritiesList}"
                                            HeightRequest="48"
                                            HorizontalScrollBarVisibility="Never">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:PriorityItem">
                                        <Border StrokeShape="RoundRectangle 20" 
                                                StrokeThickness="1"
                                                Padding="20,0"
                                                VerticalOptions="Center"
                                                HeightRequest="40"
                                                BackgroundColor="Transparent">
                                            
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                                    <Setter Property="Stroke" Value="{DynamicResource Theme_Dust_Ocean}" />
                                                </DataTrigger>
                                                
                                                <MultiTrigger TargetType="Border">
                                                    <MultiTrigger.Conditions>
                                                        <BindingCondition Binding="{Binding IsSelected}" Value="True" />
                                                        <BindingCondition Binding="{Binding Value}" Value="Low" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Sage}" />
                                                    <Setter Property="Stroke" Value="{DynamicResource Theme_Sage}" />
                                                </MultiTrigger>
                                                
                                                <MultiTrigger TargetType="Border">
                                                    <MultiTrigger.Conditions>
                                                        <BindingCondition Binding="{Binding IsSelected}" Value="True" />
                                                        <BindingCondition Binding="{Binding Value}" Value="Medium" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Amber}" />
                                                    <Setter Property="Stroke" Value="{DynamicResource Theme_Amber}" />
                                                </MultiTrigger>
                                                
                                                <MultiTrigger TargetType="Border">
                                                    <MultiTrigger.Conditions>
                                                        <BindingCondition Binding="{Binding IsSelected}" Value="True" />
                                                        <BindingCondition Binding="{Binding Value}" Value="High" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Coral}" />
                                                    <Setter Property="Stroke" Value="{DynamicResource Theme_Coral}" />
                                                </MultiTrigger>
                                            </Border.Triggers>
                                            
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TodoDetailViewModel}}, Path=SelectPriorityCommand}" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            
                                            <Label Text="{Binding DisplayName}" InputTransparent="True" HorizontalOptions="Center" VerticalOptions="Center" FontSize="13" FontAttributes="Bold">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="TextColor" Value="{DynamicResource Theme_Snow_Midnight}" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                        <Setter Property="TextColor" Value="{DynamicResource Theme_Midnight_Snow}" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        HeightRequest="48"
                        BackgroundColor="{DynamicResource Theme_Ocean_Ocean}">
                    <Border.Shadow>
                        <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,4" Radius="8" Opacity="0.2" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SaveCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="{x:Static localization:AppResources.SaveTaskButton}"
                           InputTransparent="True"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{DynamicResource Theme_Snow_Midnight}" />
                </Border>
        </Grid>
    </Grid>
</ContentPage>