<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             x:Class="Diarion.Views.DiaryDetailPage"
             x:DataType="viewmodels:DiaryDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource Earth}, Dark={StaticResource Midnight}}">

    <Grid RowDefinitions="Auto,*">
        <Grid Padding="24,18,24,6" ColumnDefinitions="Auto,*,Auto">
            <Grid Grid.Column="0" Padding="10" BackgroundColor="Transparent" VerticalOptions="Center">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="✕" FontSize="22" InputTransparent="True" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
            </Grid>

            <VerticalStackLayout Grid.Column="1" Spacing="2">
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                <Label Text="{x:Static localization:AppResources.Subtitle}" FontSize="10" CharacterSpacing="1.4" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
            </VerticalStackLayout>

            <ActivityIndicator Grid.Column="2"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               WidthRequest="24"
                               HeightRequest="24"
                               Color="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,10,24,24" Spacing="14">
                <Border StrokeShape="RoundRectangle 24"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}"
                        Padding="18,18">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Midnight}" Offset="0,6" Radius="12" Opacity="{AppThemeBinding Light=0.06, Dark=0.3}" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.TitleLabel}" FontAttributes="Bold" FontSize="10" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Entry Text="{Binding EntryTitle}"
                                   Placeholder="{x:Static localization:AppResources.TitlePlaceholder}"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}"
                                   TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}"
                                   BackgroundColor="Transparent"
                                   HeightRequest="42" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}" Opacity="0.5" />

                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.EmotionLabel}" FontAttributes="Bold" FontSize="10" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Picker ItemsSource="{Binding EmotionsList}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedEmotionItem}"
                                    Title="{x:Static localization:AppResources.EmotionPlaceholder}"
                                    TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}"
                                    TitleColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="42" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}" Opacity="0.5" />

                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.ContentLabel}" FontAttributes="Bold" FontSize="10" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Editor Text="{Binding EntryContent}"
                                    Placeholder="{x:Static localization:AppResources.ContentPlaceholder}"
                                    PlaceholderColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}"
                                    TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="200"
                                    AutoSize="Disabled" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        HeightRequest="48"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Ocean}}">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Midnight}" Offset="0,4" Radius="8" Opacity="0.2" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SaveCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="{x:Static localization:AppResources.SaveButton}"
                           InputTransparent="True"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Midnight}}" />
                </Border>

                <Border StrokeShape="RoundRectangle 14"
                        StrokeThickness="0"
                        HeightRequest="48"
                        IsVisible="{Binding IsExistingEntry}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Dust}}">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Midnight}" Offset="0,4" Radius="8" Opacity="0.2" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DeleteCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="{x:Static localization:AppResources.DeleteButton}"
                           InputTransparent="True"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Midnight}}" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
