<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:stats="clr-namespace:Diarion.ViewModels.Statistics;assembly=Diarion.Core"
             x:Class="Diarion.Views.StatisticsPage"
             x:DataType="viewmodels:StatisticsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource Theme_Earth_Midnight}">

    <ScrollView>
        <VerticalStackLayout Padding="24,18,24,32" Spacing="20">
            
            <Grid Margin="0,0,0,8">
                <!-- Заголовок -->
                <Label Text="{Binding Title}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                
                <!-- Streak Badge -->
                <Grid WidthRequest="64" HeightRequest="64" HorizontalOptions="End" VerticalOptions="Center" IsVisible="{Binding IsStreakVisible}">
                    <!-- Зовнішня рамка -->
                    <Border Stroke="{DynamicResource Theme_Coral}" 
                            StrokeThickness="1.5" 
                            WidthRequest="56" 
                            HeightRequest="56"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            BackgroundColor="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                    </Border>

                    <!-- Вміст: вогник та текст -->
                    <VerticalStackLayout HorizontalOptions="Center" 
                                         VerticalOptions="Center" 
                                         Spacing="-2"
                                         Margin="0,4,0,0">
                        
                        <Label Text="🔥" 
                               FontSize="22" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" />
                        
                        <Label Text="{Binding CurrentStreak}" 
                               FontSize="16" 
                               FontAttributes="Bold" 
                               TextColor="{DynamicResource Theme_Midnight_Snow}" 
                               HorizontalOptions="Center" 
                               VerticalOptions="Center" />
                               
                    </VerticalStackLayout>
                </Grid>
            </Grid>
            
            <!-- Tab Selector -->
            <CollectionView ItemsSource="{Binding Tabs}" ItemsLayout="HorizontalList" HeightRequest="40" Margin="0,0,0,8" HorizontalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:StatisticsTabItem">
                        <Border Padding="16,0" Margin="0,0,8,0" HeightRequest="36" StrokeShape="RoundRectangle 18"
                                Stroke="{DynamicResource Theme_Dust_Ocean}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Midnight_Snow}" />
                                    <Setter Property="Stroke" Value="{DynamicResource Theme_Midnight_Snow}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:StatisticsViewModel}}, Path=SelectTabCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding DisplayName}" VerticalOptions="Center" HorizontalOptions="Center" FontSize="14" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="TextColor" Value="{DynamicResource Theme_Snow_Midnight}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{DynamicResource Theme_Ocean_Dust}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Фільтр періодів -->
            <CollectionView ItemsSource="{Binding TimeRanges}" ItemsLayout="HorizontalList" HeightRequest="40" Margin="0,0,0,8" HorizontalScrollBarVisibility="Never">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:TimeRangeItem">
                        <Border Padding="16,0" Margin="0,0,8,0" HeightRequest="36" StrokeShape="RoundRectangle 18"
                                Stroke="{DynamicResource Theme_Dust_Ocean}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Dust_Ocean}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:StatisticsViewModel}}, Path=SelectTimeRangeCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding DisplayName}" VerticalOptions="Center" HorizontalOptions="Center" FontSize="14" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="TextColor" Value="{DynamicResource Theme_Snow}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="TextColor" Value="{DynamicResource Theme_Ocean_Dust}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{DynamicResource Theme_Ocean_Dust}" />

            <!-- GENERAL TAB (Mood) -->
            <VerticalStackLayout Spacing="20" IsVisible="{Binding IsGeneralTabVisible}">
                
                <VerticalStackLayout IsVisible="{Binding MoodStats.IsEmpty}" Spacing="12" HorizontalOptions="Center" Margin="0,40,0,0">
                    <Label Text="😶" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="{x:Static localization:AppResources.EmptyDataMessage}" FontSize="16" TextColor="{DynamicResource Theme_Ocean_Dust}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Mood Stats Card -->
                <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                        Stroke="{DynamicResource Theme_Dust_Ocean}"
                        BackgroundColor="{DynamicResource Theme_Snow_Black}"
                        Padding="16"
                        IsVisible="{Binding MoodStats.IsNotEmpty}">
                    <Border.Shadow>
                        <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                    </Border.Shadow>
                    
                    <VerticalStackLayout Spacing="16">
                        <Label Text="{x:Static localization:AppResources.EmotionLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Coral}" />
                        
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="24">
                            
                            <VerticalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center" BindableLayout.ItemsSource="{Binding MoodStats.EmotionChartData}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:EmotionChartItem">
                                        <Grid ColumnDefinitions="16, *, Auto" ColumnSpacing="8">
                                            <BoxView Grid.Column="0" Color="{Binding Color}" CornerRadius="8" WidthRequest="12" HeightRequest="12" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding Name}" FontSize="13" VerticalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                                            <Label Grid.Column="2" Text="{Binding Percentage, StringFormat='{0:P0}'}" FontSize="13" FontAttributes="Bold" VerticalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <controls:EmotionDonutChart Grid.Column="1" WidthRequest="100" HeightRequest="100" 
                                                        Items="{Binding MoodStats.EmotionChartData}" 
                                                        CenterText="{Binding MoodStats.EmotionChartData.Count}" 
                                                        VerticalOptions="Center" HorizontalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <Label Grid.Column="0" Text="{x:Static localization:AppResources.StatsTopEmotion}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                            <Label Grid.Column="1" Text="{Binding MoodStats.TopEmotionText}" FontAttributes="Bold" FontSize="16" HorizontalTextAlignment="End" TextColor="{DynamicResource Theme_Coral}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- SLEEP TAB -->
            <VerticalStackLayout Spacing="20" IsVisible="{Binding IsSleepTabVisible}">
                
                <VerticalStackLayout IsVisible="{Binding SleepStats.IsEmpty}" Spacing="12" HorizontalOptions="Center" Margin="0,40,0,0">
                    <Label Text="😴" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="{x:Static localization:AppResources.EmptyDataMessage}" FontSize="16" TextColor="{DynamicResource Theme_Ocean_Dust}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Sleep Stats Card -->
                <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                    BackgroundColor="{DynamicResource Theme_Snow_Black}"
                    Padding="16"
                    IsVisible="{Binding SleepStats.IsNotEmpty}">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static localization:AppResources.SleepLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Amber}" />
                    
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="{x:Static localization:AppResources.StatsSleepDuration}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        <Label Grid.Column="1" Text="{Binding SleepStats.AverageSleepDurationText}" FontAttributes="Bold" FontSize="16" HorizontalTextAlignment="End" TextColor="{DynamicResource Theme_Amber}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />
                    
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <Label Grid.Column="0" Text="{x:Static localization:AppResources.StatsSleepQuality}" VerticalOptions="Center" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                        <Label Grid.Column="1" Text="{Binding SleepStats.AverageSleepQualityText}" FontAttributes="Bold" FontSize="16" HorizontalTextAlignment="End" TextColor="{DynamicResource Theme_Amber}" />
                    </Grid>

                    <controls:SleepBarChart HeightRequest="120" Items="{Binding SleepStats.SleepChartData}" MaxValue="12" Margin="0,16,0,0" />
                </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- PRODUCTIVITY TAB -->
            <VerticalStackLayout Spacing="20" IsVisible="{Binding IsProductivityTabVisible}">
                
                <VerticalStackLayout IsVisible="{Binding ProductivityStats.IsEmpty}" Spacing="12" HorizontalOptions="Center" Margin="0,40,0,0">
                    <Label Text="✅" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="{x:Static localization:AppResources.EmptyDataMessage}" FontSize="16" TextColor="{DynamicResource Theme_Ocean_Dust}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Productivity Stats Card -->
                <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                    BackgroundColor="{DynamicResource Theme_Snow_Black}"
                    Padding="16"
                    IsVisible="{Binding ProductivityStats.IsNotEmpty}">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="16">
                    <Label Text="{x:Static localization:AppResources.StatsProductivity}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Sage}" />
                    
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="24">
                        
                        <VerticalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                            <Label Text="{x:Static localization:AppResources.StatsTasksCompleted}" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                            <Label Text="{Binding ProductivityStats.TaskStatsText}" FontSize="24" FontAttributes="Bold" TextColor="{DynamicResource Theme_Sage}" />
                        </VerticalStackLayout>

                        <controls:ProgressDonutChart Grid.Column="1" WidthRequest="80" HeightRequest="80" 
                                                     Progress="{Binding ProductivityStats.TaskCompletionPercentage}" 
                                                     ProgressColor="{DynamicResource Theme_Sage}"
                                                     CenterText="{Binding ProductivityStats.TaskCompletionText}" 
                                                     VerticalOptions="Center" HorizontalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
            
            <!-- FINANCE TAB -->
            <VerticalStackLayout Spacing="20" IsVisible="{Binding IsFinanceTabVisible}">
                
                <VerticalStackLayout IsVisible="{Binding FinanceStats.IsEmpty}" Spacing="12" HorizontalOptions="Center" Margin="0,40,0,0">
                    <Label Text="💸" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="{x:Static localization:AppResources.EmptyDataMessage}" FontSize="16" TextColor="{DynamicResource Theme_Ocean_Dust}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Finance Summary Card -->
                <Border StrokeShape="RoundRectangle 24" StrokeThickness="1"
                    Stroke="{DynamicResource Theme_Dust_Ocean}"
                    BackgroundColor="{DynamicResource Theme_Snow_Black}"
                    Padding="16"
                    IsVisible="{Binding FinanceStats.IsNotEmpty}">
                <Border.Shadow>
                    <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,6" Radius="12" Opacity="0.2" />
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="16">
                    <Label Text="{x:Static localization:AppResources.FinanceTitle}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                    
                    <!-- Overall Balances -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{x:Static localization:AppResources.IncomeLabel}" FontSize="12" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                            <Label Text="{Binding FinanceStats.TotalIncome, StringFormat='+{0:N2}'}" FontAttributes="Bold" FontSize="18" TextColor="{DynamicResource Theme_Sage}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                            <Label Text="{x:Static localization:AppResources.ExpenseLabel}" FontSize="12" TextColor="{DynamicResource Theme_Ocean_Dust}" HorizontalOptions="End" />
                            <Label Text="{Binding FinanceStats.TotalExpense, StringFormat='-{0:N2}'}" FontAttributes="Bold" FontSize="18" TextColor="{DynamicResource Theme_Coral}" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{DynamicResource Theme_Dust_Ocean}" Opacity="0.5" />

                    <!-- Expenses Chart & Legend -->
                    <Label Text="{x:Static localization:AppResources.ExpenseLabel}" FontAttributes="Bold" FontSize="14" TextColor="{DynamicResource Theme_Midnight_Snow}" Margin="0,8,0,0" />
                    
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="16">
                        
                        <VerticalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center" BindableLayout.ItemsSource="{Binding FinanceStats.ExpenseByCategory}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:CategoryStatItem">
                                    <Grid ColumnDefinitions="12, *, Auto" ColumnSpacing="8">
                                        <BoxView Grid.Column="0" Color="{Binding ColorHex}" CornerRadius="6" WidthRequest="12" HeightRequest="12" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding Category}" FontSize="13" VerticalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="2" Text="{Binding Percentage, StringFormat='{0:P0}'}" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <controls:CategoryDonutChart Grid.Column="1" WidthRequest="120" HeightRequest="120" 
                                                     Items="{Binding FinanceStats.ExpenseByCategory}" 
                                                     VerticalOptions="Center" HorizontalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>