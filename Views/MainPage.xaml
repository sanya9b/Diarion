<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             xmlns:views="clr-namespace:Diarion.Views"
             xmlns:behaviors="clr-namespace:Diarion.Behaviors"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Diarion.Views.MainPage"
             x:Name="PageRoot"
             x:DataType="viewmodels:MainViewModel"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource Theme_Earth_Midnight}">

    <Grid Padding="0" RowDefinitions="Auto, *">
        
        <!-- Custom Top Bar: Removed Hamburger Menu for Clean Minimalism -->
        <Grid Grid.Row="0" Padding="24,18,24,6" ColumnDefinitions="*, Auto" ColumnSpacing="12">
            
            <controls:QuickMenuView Grid.Column="0" HorizontalOptions="Start" />
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Up" Command="{Binding CalendarSection.ToggleCalendarCommand}" />
                <SwipeGestureRecognizer Direction="Down" Command="{Binding CalendarSection.ToggleCalendarCommand}" />
            </Grid.GestureRecognizers>

            <VerticalStackLayout Grid.Row="0" Padding="24,4,24,10" Spacing="0">
                
                <controls:CalendarView IsExpanded="{Binding BindingContext.CalendarSection.IsCalendarExpanded, Source={x:Reference PageRoot}}" BindingContext="{Binding CalendarSection}" x:DataType="viewmodels:CalendarSectionViewModel" />

                <!-- Date Typographical Editorial Style -->
                <VerticalStackLayout Margin="0,-4,0,16" Spacing="0" HorizontalOptions="Fill">
                    <Label Text="{Binding CalendarSection.SelectedDateDayName}" FontFamily="MarckScript" FontSize="28" HorizontalTextAlignment="Center" HorizontalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                </VerticalStackLayout>

                <!-- Tabs: Typography-Driven Design -->
                <HorizontalStackLayout Spacing="24" Margin="0,0,0,16" HorizontalOptions="Center">
                    <Label Text="{x:Static localization:AppResources.TabDiary}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToDiaryModeCommand}" />
                        </Label.GestureRecognizers>
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsDiaryMode}" Value="True">
                                <Setter Property="TextColor" Value="{DynamicResource Theme_Midnight_Snow}" />
                                <Setter Property="FontSize" Value="20" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsDiaryMode}" Value="False">
                                <Setter Property="TextColor" Value="{DynamicResource Theme_Ocean_Dust}" />
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontAttributes" Value="None" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <Label Text="{x:Static localization:AppResources.TabPlanner}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToPlannerModeCommand}" />
                        </Label.GestureRecognizers>
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsPlannerMode}" Value="True">
                                <Setter Property="TextColor" Value="{DynamicResource Theme_Midnight_Snow}" />
                                <Setter Property="FontSize" Value="20" />
                                <Setter Property="FontAttributes" Value="Bold" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsPlannerMode}" Value="False">
                                <Setter Property="TextColor" Value="{DynamicResource Theme_Ocean_Dust}" />
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontAttributes" Value="None" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Bento Box Content Container -->
            <Grid Grid.Row="1">
                <ScrollView x:Name="DiaryContainer" IsVisible="{Binding IsDiaryMode}" Padding="24,10,24,40">
                    
                    <!-- Bento Box Asymmetrical Grid -->
                    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto" ColumnDefinitions="*, *" RowSpacing="16" ColumnSpacing="16" BindingContext="{Binding CurrentEntry}" x:DataType="viewmodels:DiaryEntryViewModel">
                        
                        <!-- Row 0: Sleep -->
                        <controls:SleepSection Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" BindingContext="{Binding}" />
                        
                        <!-- Row 1: Health -->
                        <controls:HealthSection Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" BindingContext="{Binding}" />

                        <!-- Row 2: Food -->
                        <controls:FoodTrackerSection Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" BindingContext="{Binding}" />

                        <!-- Row 3: Habits -->
                        <controls:HabitTrackerSection Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" BindingContext="{Binding}" />

                        <!-- Row 4: Reflection / Text blocks -->
                        <controls:ReflectionSection Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" BindingContext="{Binding}" />
                    </Grid>
                </ScrollView>

                <views:PlannerView x:Name="PlannerContainer" IsVisible="{Binding BindingContext.IsPlannerMode, Source={x:Reference PageRoot}}" BindingContext="{Binding PlannerSection}" />
            </Grid>
        </Grid>

        <!-- Завантаження -->
        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Center" 
                           Color="{DynamicResource Theme_Ocean_Dust}"/>
    </Grid>

</ContentPage>