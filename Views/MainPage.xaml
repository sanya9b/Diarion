<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             xmlns:views="clr-namespace:Diarion.Views"
             xmlns:behaviors="clr-namespace:Diarion.Behaviors"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Diarion.Views.MainPage"
             x:Name="PageRoot"
             x:DataType="viewmodels:MainViewModel"
             Title="{Binding Title}"
             BackgroundColor="{DynamicResource Theme_Earth_Midnight}">

    <Grid Padding="0" RowDefinitions="Auto, *">
        
        <!-- Custom Top Bar -->
        <Grid Grid.Row="0" Padding="24,18,24,6" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
            <!-- Hamburger Menu Button -->
            <Grid Grid.Column="0" Padding="10,0">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenMenuCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="☰" FontSize="32" 
                       InputTransparent="True"
                       TextColor="{DynamicResource Theme_Midnight_Snow}" 
                       VerticalOptions="Center" HorizontalOptions="Start" />
            </Grid>
            
            <controls:QuickMenuView Grid.Column="1" />

            <!-- Streak Badge -->
            <Border Grid.Column="2" 
                    IsVisible="{Binding IsStreakVisible}"
                    StrokeThickness="1" 
                    Stroke="{DynamicResource Theme_Coral}" 
                    BackgroundColor="{DynamicResource Theme_Snow_Black}" 
                    StrokeShape="RoundRectangle 16"
                    Padding="12,0" 
                    VerticalOptions="Center" 
                    HeightRequest="36">
                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                    <Label Text="🔥" FontSize="16" VerticalOptions="Center" />
                    <Label Text="{Binding CurrentStreak}" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource Theme_Midnight_Snow}" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Up" Command="{Binding CalendarSection.ToggleCalendarCommand}" />
                <SwipeGestureRecognizer Direction="Down" Command="{Binding CalendarSection.ToggleCalendarCommand}" />
            </Grid.GestureRecognizers>

            <VerticalStackLayout Grid.Row="0" Padding="24,4,24,10" Spacing="2">
                
                <controls:CalendarView IsExpanded="{Binding BindingContext.CalendarSection.IsCalendarExpanded, Source={x:Reference PageRoot}}" BindingContext="{Binding CalendarSection}" x:DataType="viewmodels:CalendarSectionViewModel" />

                <VerticalStackLayout Margin="0,0,0,10" Spacing="0" HorizontalOptions="Fill">
                    <BoxView HeightRequest="4" WidthRequest="32" CornerRadius="2" 
                             BackgroundColor="{DynamicResource Theme_Dust_Ocean}" 
                             HorizontalOptions="Center" Margin="0,0,0,4" />
                    <Label Text="{Binding CalendarSection.SelectedDateDayName}" FontFamily="MarckScript" FontSize="32" HorizontalTextAlignment="Center" HorizontalOptions="Center" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" Margin="0,4,0,6">
                    <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="Transparent" Padding="0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToDiaryModeCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static localization:AppResources.TabDiary}"
                               InputTransparent="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontAttributes="Bold"
                               FontSize="15">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsDiaryMode}" Value="True">
                                    <Setter Property="TextColor" Value="{DynamicResource Theme_Midnight_Snow}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsDiaryMode}" Value="False">
                                    <Setter Property="TextColor" Value="{DynamicResource Theme_Ocean_Dust}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="Transparent" Padding="0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToPlannerModeCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static localization:AppResources.TabPlanner}"
                               InputTransparent="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontAttributes="Bold"
                               FontSize="15">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsPlannerMode}" Value="True">
                                    <Setter Property="TextColor" Value="{DynamicResource Theme_Midnight_Snow}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsPlannerMode}" Value="False">
                                    <Setter Property="TextColor" Value="{DynamicResource Theme_Ocean_Dust}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <BoxView Grid.Column="0" HeightRequest="2" BackgroundColor="{DynamicResource Theme_Midnight_Snow}" VerticalOptions="End" IsVisible="{Binding IsDiaryMode}" />
                    <BoxView Grid.Column="1" HeightRequest="2" BackgroundColor="{DynamicResource Theme_Midnight_Snow}" VerticalOptions="End" IsVisible="{Binding IsPlannerMode}" />
                </Grid>
            </VerticalStackLayout>

            <Grid Grid.Row="1">
                <ScrollView x:Name="DiaryContainer" IsVisible="{Binding IsDiaryMode}" Padding="24,10,24,40">
                    <VerticalStackLayout Spacing="24" BindingContext="{Binding CurrentEntry}" x:DataType="viewmodels:DiaryEntryViewModel">
                        
                        <!-- Sleep Block -->
                        <controls:SleepSection BindingContext="{Binding}" />

                        <!-- Health Block -->
                        <controls:HealthSection BindingContext="{Binding}" />

                        <!-- Food Block -->
                        <controls:FoodTrackerSection BindingContext="{Binding}" />

                        <!-- Habits Block -->
                        <controls:HabitTrackerSection BindingContext="{Binding}" />

                        <!-- Reflection / Text blocks -->
                        <controls:ReflectionSection BindingContext="{Binding}" />
                    </VerticalStackLayout>
                </ScrollView>

                <views:PlannerView x:Name="PlannerContainer" IsVisible="{Binding BindingContext.IsPlannerMode, Source={x:Reference PageRoot}}" BindingContext="{Binding PlannerSection}" />
            </Grid>
        </Grid>

        <!-- Завантаження -->
        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Center" 
                           Color="{DynamicResource Theme_Ocean_Dust}"/>
    </Grid>

</ContentPage>
