<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Diarion.Views.MainPage"
             x:Name="PageRoot"
             x:DataType="viewmodels:MainViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource Earth}, Dark={StaticResource Midnight}}">

    <Grid Padding="0" RowDefinitions="Auto, *">
        
        <!-- Custom Top Bar -->
        <Grid Grid.Row="0" Padding="24,18,24,6" ColumnDefinitions="Auto, *" ColumnSpacing="12">
            <!-- Hamburger Menu Button -->
            <Grid Grid.Column="0" Padding="10,0">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenMenuCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="☰" FontSize="32" 
                       InputTransparent="True"
                       TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" 
                       VerticalOptions="Center" HorizontalOptions="Start" />
            </Grid>
            
            <ScrollView Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        VerticalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8" Padding="6,0,0,0">
                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}"
                            Padding="0"
                            WidthRequest="50"
                            HeightRequest="50"
                            Margin="0,0,2,0">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16,16,0,0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}"
                                    Padding="0,2">
                                <Label Text="{Binding TodayMonthShort}"
                                       InputTransparent="True"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontSize="9"
                                       FontAttributes="Bold"
                                       CharacterSpacing="1.2"
                                       TextColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Midnight}}" />
                            </Border>
                            <Label Grid.Row="1"
                                   Text="{Binding TodayDayNumber}"
                                   InputTransparent="True"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />

                            <BoxView Grid.RowSpan="2" BackgroundColor="Transparent">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToTodayCommand}" />
                                </BoxView.GestureRecognizers>
                            </BoxView>
                        </Grid>
                    </Border>

                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="{StaticResource Coral}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}"
                            Padding="0"
                            WidthRequest="50"
                            HeightRequest="50">
                        <Grid BackgroundColor="Transparent">
                            <Image Source="habit_tracker.svg"
                                   InputTransparent="True"
                                   WidthRequest="22"
                                   HeightRequest="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Aspect="AspectFit">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{StaticResource Coral}" />
                                </Image.Behaviors>
                            </Image>

                            <BoxView BackgroundColor="Transparent">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenHabitTrackerCommand}" />
                                </BoxView.GestureRecognizers>
                            </BoxView>
                        </Grid>
                    </Border>

                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="{StaticResource Sage}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}"
                            Padding="0"
                            WidthRequest="50"
                            HeightRequest="50">
                        <Grid BackgroundColor="Transparent">
                            <Image Source="reading_tracker.svg"
                                   InputTransparent="True"
                                   WidthRequest="22"
                                   HeightRequest="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Aspect="AspectFit">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{StaticResource Sage}" />
                                </Image.Behaviors>
                            </Image>

                            <BoxView BackgroundColor="Transparent">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenReadingTrackerCommand}" />
                                </BoxView.GestureRecognizers>
                            </BoxView>
                        </Grid>
                    </Border>

                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="{StaticResource Berry}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}"
                            Padding="0"
                            WidthRequest="50"
                            HeightRequest="50">
                        <Grid BackgroundColor="Transparent">
                            <Image Source="happy_moments.svg"
                                   InputTransparent="True"
                                   WidthRequest="22"
                                   HeightRequest="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Aspect="AspectFit">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{StaticResource Berry}" />
                                </Image.Behaviors>
                            </Image>

                            <BoxView BackgroundColor="Transparent">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenHappyMomentsCommand}" />
                                </BoxView.GestureRecognizers>
                            </BoxView>
                        </Grid>
                    </Border>

                    <Border StrokeShape="RoundRectangle 16"
                            StrokeThickness="1"
                            Stroke="{StaticResource Amber}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}"
                            Padding="0"
                            WidthRequest="50"
                            HeightRequest="50">
                        <Grid BackgroundColor="Transparent">
                            <Image Source="good_deeds.svg"
                                   InputTransparent="True"
                                   WidthRequest="22"
                                   HeightRequest="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Aspect="AspectFit">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{StaticResource Amber}" />
                                </Image.Behaviors>
                            </Image>

                            <BoxView BackgroundColor="Transparent">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenGoodDeedsCommand}" />
                                </BoxView.GestureRecognizers>
                            </BoxView>
                        </Grid>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Up" Command="{Binding ToggleCalendarCommand}" />
                <SwipeGestureRecognizer Direction="Down" Command="{Binding ToggleCalendarCommand}" />
            </Grid.GestureRecognizers>

            <VerticalStackLayout Grid.Row="0" Padding="24,4,24,10" Spacing="2">
                
                <Grid x:Name="CalendarSection" RowDefinitions="Auto, Auto" IsClippedToBounds="True">
                    <Grid x:Name="CalendarHeader" Grid.Row="0" RowDefinitions="Auto, Auto">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,4,0,12">
                            <Grid Grid.Column="0" BackgroundColor="Transparent" Padding="20,10" VerticalOptions="Center" HorizontalOptions="Start">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PreviousMonthCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="&lt;" FontSize="32" InputTransparent="True" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            </Grid>

                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="-10">
                                <Label Text="{Binding CurrentMonthName}" FontFamily="MarckScript" FontSize="40" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" HorizontalOptions="Center" />
                                <Label Text="{Binding CurrentYear}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <Grid Grid.Column="2" BackgroundColor="Transparent" Padding="20,10" VerticalOptions="Center" HorizontalOptions="End">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="&gt;" FontSize="32" InputTransparent="True" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Margin="0,0,0,8">
                            <Label Grid.Column="0" Text="{x:Static localization:AppResources.WeekdayMonShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="1" Text="{x:Static localization:AppResources.WeekdayTueShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="2" Text="{x:Static localization:AppResources.WeekdayWedShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="3" Text="{x:Static localization:AppResources.WeekdayThuShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="4" Text="{x:Static localization:AppResources.WeekdayFriShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="5" Text="{x:Static localization:AppResources.WeekdaySatShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="6" Text="{x:Static localization:AppResources.WeekdaySunShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                        </Grid>
                    </Grid>

                    <FlexLayout Grid.Row="1" x:Name="CalendarGrid" BindableLayout.ItemsSource="{Binding CalendarDays}"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="SpaceBetween"
                              AlignContent="Start">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:CalendarDay">
                            <ContentView FlexLayout.Basis="13.5%" HeightRequest="52" Margin="0,0,0,8">
                                <Grid>
                                    <Border StrokeShape="RoundRectangle 8"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark=#1AFFFFFF}"
                                            Padding="6">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.SelectDateCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsPredictedCycleDay}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource BerryTransparent}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsCycleDay}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource BerryTransparent}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="StrokeThickness" Value="1.5" />
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Grid>
                                        <!-- Day Number (Top Left) -->
                                        <Label Text="{Binding Day}" HorizontalOptions="Start" VerticalOptions="Start" FontSize="13" InputTransparent="True" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsCurrentMonth}" Value="False">
                                                    <Setter Property="Opacity" Value="0.25" />
                                                </DataTrigger>
                                                <!-- IsCycleDay no longer forces Snow text color because BerryTransparent is lighter -->
                                                <DataTrigger TargetType="Label" Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Midnight}}" />
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        
                                        <!-- Pacifier icon for fertile window (Bottom Left) -->
                                        <Image Source="pacifier.png" WidthRequest="16" HeightRequest="16" HorizontalOptions="Start" VerticalOptions="End" Aspect="AspectFit" InputTransparent="True" IsVisible="{Binding IsFertileWindow}" Margin="-2,0,0,-2">
                                            <Image.Behaviors>
                                                <toolkit:IconTintColorBehavior TintColor="{StaticResource Berry}" />
                                            </Image.Behaviors>
                                        </Image>

                                        <!-- Priority Task Dot (Bottom Right) -->
                                        <Ellipse Fill="{Binding PriorityDotColor}" WidthRequest="6" HeightRequest="6" HorizontalOptions="End" VerticalOptions="End" IsVisible="{Binding HasTasks}" InputTransparent="True" />
                                    </Grid>
                                </Border>
                                
                                <!-- Progress Border Overlay OUTSIDE the clipping mask -->
                                <controls:ProgressBorder Progress="{Binding TaskCompletionPercentage}" 
                                                         StrokeColor="{Binding ProgressColor}"
                                                         CornerRadius="8"
                                                         InputTransparent="True" />
                                </Grid>
                            </ContentView>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
                </Grid>

                <VerticalStackLayout Margin="0,0,0,10" Spacing="0" HorizontalOptions="Fill">
                    <Label Text="{Binding SelectedDateDayName}" FontFamily="MarckScript" FontSize="32" HorizontalTextAlignment="Center" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" Margin="0,4,0,6">
                    <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="Transparent" Padding="0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToDiaryModeCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static localization:AppResources.TabDiary}"
                               InputTransparent="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontAttributes="Bold"
                               FontSize="15">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsDiaryMode}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsDiaryMode}" Value="False">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="Transparent" Padding="0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToPlannerModeCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static localization:AppResources.TabPlanner}"
                               InputTransparent="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontAttributes="Bold"
                               FontSize="15">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsPlannerMode}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsPlannerMode}" Value="False">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <BoxView Grid.Column="0" HeightRequest="2" BackgroundColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" VerticalOptions="End" IsVisible="{Binding IsDiaryMode}" />
                    <BoxView Grid.Column="1" HeightRequest="2" BackgroundColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" VerticalOptions="End" IsVisible="{Binding IsPlannerMode}" />
                </Grid>
            </VerticalStackLayout>

            <Grid Grid.Row="1">
                <ScrollView x:Name="DiaryContainer" IsVisible="True" Padding="24,10,24,40">
                    <VerticalStackLayout Spacing="24" BindingContext="{Binding CurrentEntry}" x:DataType="models:DiaryEntry">
                        
                        <!-- Sleep Block -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.SleepLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Grid ColumnDefinitions="Auto, *, Auto, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="{x:Static localization:AppResources.SleepStartLabel}" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Grid Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding SleepStart, StringFormat='{0:HH\\:mm}'}" 
                                           IsVisible="{Binding HasSleepStart}"
                                           TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" FontSize="14" VerticalOptions="Center" />
                                    <Label Text="HH:mm" 
                                           IsVisible="{Binding IsSleepStartEmpty}"
                                           TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" FontSize="14" VerticalOptions="Center" />
                                    <!-- Transparent TimePicker intercepts touches and opens the native dialog -->
                                    <TimePicker Time="{Binding SleepStart, TargetNullValue='00:00', FallbackValue='00:00'}" Format="HH:mm"
                                                Opacity="0.01" HeightRequest="36" />
                                </Grid>

                                <Label Grid.Column="2" Text="{x:Static localization:AppResources.SleepEndLabel}" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Grid Grid.Column="3" VerticalOptions="Center">
                                    <Label Text="{Binding SleepEnd, StringFormat='{0:HH\\:mm}'}" 
                                           IsVisible="{Binding HasSleepEnd}"
                                           TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" FontSize="14" VerticalOptions="Center" />
                                    <Label Text="HH:mm" 
                                           IsVisible="{Binding IsSleepEndEmpty}"
                                           TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" FontSize="14" VerticalOptions="Center" />
                                    <TimePicker Time="{Binding SleepEnd, TargetNullValue='00:00', FallbackValue='00:00'}" Format="HH:mm"
                                                Opacity="0.01" HeightRequest="36" />
                                </Grid>
                            </Grid>
                            <Grid ColumnDefinitions="110, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="{x:Static localization:AppResources.SleepQualityLabel}" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <controls:RatingView Grid.Column="1" Value="{Binding SleepQuality}" MaxValue="10" VerticalOptions="Center" HorizontalOptions="Start" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Health Block -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.HealthLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            
                            <Grid ColumnDefinitions="110, *" ColumnSpacing="12" IsVisible="{Binding BindingContext.IsCycleInfoVisible, Source={x:Reference PageRoot}}">
                                <Label Grid.Column="0" Text="{x:Static localization:AppResources.CycleDayLabel}" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding BindingContext.CycleDayText, Source={x:Reference PageRoot}}" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="{x:Static localization:AppResources.PregnancyProbabilityLabel}" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                        <Label Text="{Binding BindingContext.PregnancyProbabilityText, Source={x:Reference PageRoot}}" FontSize="11" FontAttributes="Bold" TextColor="{Binding BindingContext.PregnancyProbabilityColor, Source={x:Reference PageRoot}}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="110, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="{x:Static localization:AppResources.HealthStatusLabel}" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <controls:RatingView Grid.Column="1" Value="{Binding HealthStatus}" MaxValue="10" VerticalOptions="Center" HorizontalOptions="Start" />
                            </Grid>
                            <Grid ColumnDefinitions="110, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="{x:Static localization:AppResources.IntimateLifeLabel}" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="1" Text="{Binding IntimateLife}" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Habits Block -->
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                <Label Grid.Column="0" Text="{x:Static localization:AppResources.HabitsLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" VerticalOptions="Center" />
                                <Grid Grid.Column="1" Padding="10,4" BackgroundColor="Transparent">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.ToggleEditHabitsModeCommand, Source={x:Reference PageRoot}}" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="✎" FontSize="16" InputTransparent="True" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                </Grid>
                            </Grid>
                            
                            <FlexLayout BindableLayout.ItemsSource="{Binding Habits}" Wrap="Wrap" Direction="Row" JustifyContent="SpaceBetween">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:HabitItem">
                                        <ContentView FlexLayout.Basis="48%">
                                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="6" HeightRequest="36">
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}" VerticalOptions="Center" Scale="0.8" Margin="-8,0,-4,0" />
                                                <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" FontSize="12" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                                
                                                <Grid Grid.Column="2" 
                                                      WidthRequest="20" HeightRequest="20" 
                                                      VerticalOptions="Center" 
                                                      BackgroundColor="Transparent"
                                                      IsVisible="{Binding BindingContext.IsEditHabitsMode, Source={x:Reference PageRoot}}">
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding BindingContext.DeleteHabitCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                                    </Grid.GestureRecognizers>
                                                    <Label Text="✖" FontSize="12" InputTransparent="True" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{StaticResource Coral}" />
                                                </Grid>
                                            </Grid>
                                        </ContentView>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                            
                            <Button Text="{x:Static localization:AppResources.AddHabitLabel}"
                                    Command="{Binding BindingContext.AddHabitCommand, Source={x:Reference PageRoot}}"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Start"
                                    Padding="0,8" />
                        </VerticalStackLayout>

                        <!-- Reflection / Text blocks -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.TriggersLabel}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                            <Editor Text="{Binding Triggers}" BackgroundColor="Transparent" FontSize="14" HeightRequest="60" AutoSize="Disabled" />
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.GratitudeLabel}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                            <Editor Text="{Binding Gratitude}" BackgroundColor="Transparent" FontSize="14" HeightRequest="60" AutoSize="Disabled" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="{x:Static localization:AppResources.SoulFoodLabel}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                            <Editor Text="{Binding SoulFood}" BackgroundColor="Transparent" FontSize="14" HeightRequest="60" AutoSize="Disabled" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <ContentView x:Name="PlannerContainer" IsVisible="False" />
            </Grid>
        </Grid>

        <!-- Завантаження -->
        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Center" 
                           Color="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}"/>
    </Grid>

</ContentPage>
