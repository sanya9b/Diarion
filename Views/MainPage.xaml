<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             x:Class="Diarion.Views.MainPage"
             x:Name="PageRoot"
             x:DataType="viewmodels:MainViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource Earth}, Dark={StaticResource Midnight}}">

    <Grid Padding="0" RowDefinitions="Auto, *">
        
        <!-- Custom Top Bar -->
        <Grid Grid.Row="0" Padding="24,18,24,6" ColumnDefinitions="Auto, *">
            <!-- Hamburger Menu Button -->
            <Grid Grid.Column="0" Padding="10,0">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenMenuCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="≡" FontSize="32" 
                       InputTransparent="True"
                       TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" 
                       VerticalOptions="Center" HorizontalOptions="Start" />
            </Grid>
            
            <!-- TODAY Label -->
            <Grid Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" BackgroundColor="Transparent" Padding="10,5">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToTodayCommand}" />
                </Grid.GestureRecognizers>
                <Label Text="{x:Static localization:AppResources.TodayLabel}" 
                       InputTransparent="True"
                       HorizontalOptions="Center" VerticalOptions="Center" 
                       TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" 
                       CharacterSpacing="2" FontSize="11" />
            </Grid>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Up" Command="{Binding ToggleCalendarCommand}" />
                <SwipeGestureRecognizer Direction="Down" Command="{Binding ToggleCalendarCommand}" />
            </Grid.GestureRecognizers>

            <VerticalStackLayout Grid.Row="0" Padding="24,4,24,10" Spacing="2">
                
                <Grid x:Name="CalendarSection" RowDefinitions="Auto, Auto" IsClippedToBounds="True">
                    <Grid x:Name="CalendarHeader" Grid.Row="0" RowDefinitions="Auto, Auto">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,4,0,12">
                            <Grid Grid.Column="0" BackgroundColor="Transparent" Padding="20,10" VerticalOptions="Center" HorizontalOptions="Start">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PreviousMonthCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="&lt;" FontSize="32" InputTransparent="True" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            </Grid>

                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="-10">
                                <Label Text="{Binding CurrentMonthName}" FontFamily="MarckScript" FontSize="40" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" HorizontalOptions="Center" />
                                <Label Text="{Binding CurrentYear}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <Grid Grid.Column="2" BackgroundColor="Transparent" Padding="20,10" VerticalOptions="Center" HorizontalOptions="End">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Text="&gt;" FontSize="32" InputTransparent="True" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Margin="0,0,0,8">
                            <Label Grid.Column="0" Text="{x:Static localization:AppResources.WeekdayMonShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="1" Text="{x:Static localization:AppResources.WeekdayTueShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="2" Text="{x:Static localization:AppResources.WeekdayWedShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="3" Text="{x:Static localization:AppResources.WeekdayThuShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="4" Text="{x:Static localization:AppResources.WeekdayFriShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="5" Text="{x:Static localization:AppResources.WeekdaySatShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Label Grid.Column="6" Text="{x:Static localization:AppResources.WeekdaySunShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                        </Grid>
                    </Grid>

                    <FlexLayout Grid.Row="1" x:Name="CalendarGrid" BindableLayout.ItemsSource="{Binding CalendarDays}"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignContent="Start"
                            HeightRequest="252">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:CalendarDay">
                            <ContentView FlexLayout.Basis="14.28%" HeightRequest="42">
                                <Grid HeightRequest="36" WidthRequest="36" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.SelectDateCommand, Source={x:Reference PageRoot}}" CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    
                                    <Border StrokeShape="RoundRectangle 18"
                                            StrokeThickness="0"
                                            BackgroundColor="Transparent"
                                            Opacity="1">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="StrokeThickness" Value="1" />
                                                <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}" />
                                                <Setter Property="Opacity" Value="0.5" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsCurrentMonth}" Value="False">
                                                <Setter Property="Opacity" Value="0.25" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    
                                    <controls:ProgressRing Progress="{Binding TaskCompletionPercentage}" 
                                                           RingColor="{Binding ProgressColor}"
                                                           WidthRequest="36" HeightRequest="36" 
                                                           HorizontalOptions="Center" VerticalOptions="Center"
                                                           InputTransparent="True" />

                                    <Label Text="{Binding Day}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="13"
                                           InputTransparent="True"
                                           TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}">
                                         <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsCurrentMonth}" Value="False">
                                                <Setter Property="Opacity" Value="0.25" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </ContentView>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
                </Grid>

                <VerticalStackLayout Margin="0,12,0,6" Spacing="0" HorizontalOptions="Fill">
                    <Label Text="{Binding SelectedDateDayName}" FontFamily="MarckScript" FontSize="32" HorizontalTextAlignment="Center" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" Margin="0,4,0,6">
                    <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="Transparent" Padding="0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToDiaryModeCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static localization:AppResources.TabDiary}"
                               InputTransparent="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontAttributes="Bold"
                               FontSize="15">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsDiaryMode}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsDiaryMode}" Value="False">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="Transparent" Padding="0,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SwitchToPlannerModeCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static localization:AppResources.TabPlanner}"
                               InputTransparent="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontAttributes="Bold"
                               FontSize="15">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsPlannerMode}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsPlannerMode}" Value="False">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <BoxView Grid.Column="0" HeightRequest="2" BackgroundColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" VerticalOptions="End" IsVisible="{Binding IsDiaryMode}" />
                    <BoxView Grid.Column="1" HeightRequest="2" BackgroundColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" VerticalOptions="End" IsVisible="{Binding IsPlannerMode}" />
                </Grid>
            </VerticalStackLayout>

            <Grid Grid.Row="1">
                <ScrollView x:Name="DiaryContainer" IsVisible="True" Padding="24,10,24,40">
                    <VerticalStackLayout Spacing="24" BindingContext="{Binding CurrentEntry}">
                        
                        <!-- Sleep Block -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="СОН" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Grid ColumnDefinitions="Auto, *, Auto, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Початок:" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <TimePicker Grid.Column="1" Time="{Binding SleepStart}" Format="HH:mm" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                                <Label Grid.Column="2" Text="Пробудження:" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <TimePicker Grid.Column="3" Time="{Binding SleepEnd}" Format="HH:mm" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Якість сну:" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <controls:RatingView Grid.Column="1" Value="{Binding SleepQuality}" MaxValue="10" VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Health Block -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ФІЗІОЛОГІЯ ТА ЗДОРОВ'Я" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="День циклу:" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="1" Text="{Binding CycleDay}" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Стан здоров'я:" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <controls:RatingView Grid.Column="1" Value="{Binding HealthStatus}" MaxValue="10" VerticalOptions="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="Інтимне життя:" VerticalOptions="Center" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="1" Text="{Binding IntimateLife}" BackgroundColor="Transparent" FontSize="14" HeightRequest="36" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Habits Block -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ЗВИЧКИ" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}" />
                            
                            <!-- Habit template: Checkbox + Label + Entry line -->
                            <Grid ColumnDefinitions="Auto, 120, *" ColumnSpacing="8" HeightRequest="36">
                                <CheckBox Grid.Column="0" IsChecked="{Binding PhysicalActivity.IsCompleted}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Фізична активність" VerticalOptions="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="2" Text="{Binding PhysicalActivity.Note}" BackgroundColor="Transparent" FontSize="12" />
                            </Grid>
                            
                            <Grid ColumnDefinitions="Auto, 120, *" ColumnSpacing="8" HeightRequest="36">
                                <CheckBox Grid.Column="0" IsChecked="{Binding Breakfast.IsCompleted}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Сніданок" VerticalOptions="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="2" Text="{Binding Breakfast.Note}" BackgroundColor="Transparent" FontSize="12" />
                            </Grid>
                            
                            <Grid ColumnDefinitions="Auto, 120, *" ColumnSpacing="8" HeightRequest="36">
                                <CheckBox Grid.Column="0" IsChecked="{Binding Lunch.IsCompleted}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Обід" VerticalOptions="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="2" Text="{Binding Lunch.Note}" BackgroundColor="Transparent" FontSize="12" />
                            </Grid>
                            
                            <Grid ColumnDefinitions="Auto, 120, *" ColumnSpacing="8" HeightRequest="36">
                                <CheckBox Grid.Column="0" IsChecked="{Binding Dinner.IsCompleted}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Вечеря" VerticalOptions="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="2" Text="{Binding Dinner.Note}" BackgroundColor="Transparent" FontSize="12" />
                            </Grid>
                            
                            <Grid ColumnDefinitions="Auto, 120, *" ColumnSpacing="8" HeightRequest="36">
                                <CheckBox Grid.Column="0" IsChecked="{Binding Water.IsCompleted}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Вода" VerticalOptions="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="2" Text="{Binding Water.Note}" BackgroundColor="Transparent" FontSize="12" />
                            </Grid>
                            
                            <Grid ColumnDefinitions="Auto, 120, *" ColumnSpacing="8" HeightRequest="36">
                                <CheckBox Grid.Column="0" IsChecked="{Binding Vitamins.IsCompleted}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="Вітаміни/Ліки" VerticalOptions="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                                <Entry Grid.Column="2" Text="{Binding Vitamins.Note}" BackgroundColor="Transparent" FontSize="12" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Reflection / Text blocks -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ТРИГЕРИ:" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                            <Editor Text="{Binding Triggers}" BackgroundColor="Transparent" FontSize="14" HeightRequest="60" AutoSize="Disabled" />
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ВДЯЧНІСТЬ:" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                            <Editor Text="{Binding Gratitude}" BackgroundColor="Transparent" FontSize="14" HeightRequest="60" AutoSize="Disabled" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="ЇЖА ДЛЯ ДУШІ:" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                            <Editor Text="{Binding SoulFood}" BackgroundColor="Transparent" FontSize="14" HeightRequest="60" AutoSize="Disabled" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <ContentView x:Name="PlannerContainer" IsVisible="False" />
            </Grid>
        </Grid>

        <!-- Завантаження -->
        <ActivityIndicator IsRunning="{Binding IsBusy}" 
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Center" 
                           Color="{AppThemeBinding Light={StaticResource Ocean}, Dark={StaticResource Dust}}"/>
    </Grid>

</ContentPage>
