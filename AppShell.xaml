<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Diarion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Diarion.Views"
    xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
    Title="{x:Static localization:AppResources.AppTitle}"
    FlyoutBehavior="Flyout"
    Shell.NavBarIsVisible="False"
    Shell.FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource Earth}, Dark={StaticResource Midnight}}">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="140" Padding="24,32,24,16" RowDefinitions="Auto,*">
            <Image Grid.Row="0"
                   Source="app_logo.png"
                   HeightRequest="48"
                   WidthRequest="48"
                   HorizontalOptions="Start"
                   VerticalOptions="Start" />
            <Label Grid.Row="1"
                   Text="{x:Static localization:AppResources.AppTitle}" 
                   FontAttributes="Bold" 
                   FontSize="28" 
                   VerticalOptions="End" 
                   TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
        </Grid>
    </Shell.FlyoutHeader>

    <Shell.FlyoutFooter>
        <HorizontalStackLayout Padding="24" Spacing="16" Margin="0,0,0,32" HorizontalOptions="Center">
            <!-- Language Switch -->
            <Grid HeightRequest="40" WidthRequest="110" VerticalOptions="Center">
                
                <!-- Background Pill -->
                <Border StrokeShape="RoundRectangle 20" 
                        StrokeThickness="1" 
                        Stroke="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}" />
                
                <!-- Moving Thumb -->
                <Border x:Name="LangThumb"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}"
                        WidthRequest="50"
                        HorizontalOptions="Start"
                        Margin="4">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Midnight}" Offset="0,2" Radius="4" Opacity="0.2" />
                    </Border.Shadow>
                </Border>
                        
                <!-- Text -->
                <Grid ColumnDefinitions="*,*">
                    <Label Grid.Column="0" Text="🇬🇧 EN" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                    <Label Grid.Column="1" Text="🇺🇦 UA" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Midnight}, Dark={StaticResource Snow}}" />
                </Grid>

                <!-- ABSOLUTE HITBOX -->
                <BoxView BackgroundColor="Transparent" HorizontalOptions="Fill" VerticalOptions="Fill">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleLanguageClicked" />
                    </BoxView.GestureRecognizers>
                </BoxView>
            </Grid>

            <!-- Theme Switch -->
            <Grid HeightRequest="40" WidthRequest="110" VerticalOptions="Center">
                
                <!-- Background Pill -->
                <Border StrokeShape="RoundRectangle 20" 
                        StrokeThickness="1" 
                        Stroke="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Snow}, Dark={StaticResource Black}}" />
                
                <!-- Moving Thumb -->
                <Border x:Name="ThemeThumb"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Dust}, Dark={StaticResource Ocean}}"
                        WidthRequest="50"
                        HorizontalOptions="Start"
                        Margin="4">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Midnight}" Offset="0,2" Radius="4" Opacity="0.2" />
                    </Border.Shadow>
                </Border>
                        
                <!-- Text/Icons -->
                <Grid ColumnDefinitions="*,*">
                    <!-- Light Theme -->
                    <Label Grid.Column="0" Text="☀️" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                    <!-- Dark Theme -->
                    <Label Grid.Column="1" Text="🌙" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                </Grid>

                <!-- ABSOLUTE HITBOX -->
                <BoxView BackgroundColor="Transparent" HorizontalOptions="Fill" VerticalOptions="Fill">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleThemeClicked" />
                    </BoxView.GestureRecognizers>
                </BoxView>
            </Grid>
        </HorizontalStackLayout>
    </Shell.FlyoutFooter>

    <FlyoutItem Title="{x:Static localization:AppResources.MyEntriesTitle}">
        <ShellContent Route="MainPage" ContentTemplate="{DataTemplate views:MainPage}" />
    </FlyoutItem>
    <FlyoutItem Title="{x:Static localization:AppResources.ProfileMenuTitle}">
        <ShellContent Route="ProfilePage" ContentTemplate="{DataTemplate views:ProfilePage}" />
    </FlyoutItem>

</Shell>
