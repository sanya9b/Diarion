<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Diarion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Diarion.Views"
    xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
    Title="{x:Static localization:AppResources.AppTitle}"
    FlyoutBehavior="Flyout"
    Shell.NavBarIsVisible="False"
    Shell.FlyoutBackgroundColor="{DynamicResource Theme_Earth_Midnight}">

    <FlyoutItem Title="{x:Static localization:AppResources.MyEntriesTitle}">
        <ShellContent Route="MainPage" ContentTemplate="{DataTemplate views:MainPage}" />
    </FlyoutItem>
    <FlyoutItem Title="{x:Static localization:AppResources.StatisticsMenuTitle}">
        <ShellContent Route="StatisticsPage" ContentTemplate="{DataTemplate views:StatisticsPage}" />
    </FlyoutItem>
    <FlyoutItem Title="{x:Static localization:AppResources.ProfileMenuTitle}">
        <ShellContent Route="ProfilePage" ContentTemplate="{DataTemplate views:ProfilePage}" />
    </FlyoutItem>

</Shell>