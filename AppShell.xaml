<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Diarion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Diarion.Views"
    xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
    Title="{x:Static localization:AppResources.AppTitle}"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="{DynamicResource Theme_Snow_Black}"
    Shell.TabBarUnselectedColor="{DynamicResource Theme_Ocean_Dust}"
    Shell.TabBarTitleColor="{DynamicResource Theme_Midnight_Snow}">

    <TabBar>
        <Tab Title="{x:Static localization:AppResources.MyEntriesTitle}" Icon="tab_entries.png">
            <ShellContent Route="MainPage" ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="{x:Static localization:AppResources.StatisticsMenuTitle}" Icon="tab_stats.png">
            <ShellContent Route="StatisticsPage" ContentTemplate="{DataTemplate views:StatisticsPage}" />
        </Tab>
        <Tab Title="{x:Static localization:AppResources.ProfileMenuTitle}" Icon="tab_profile.png">
            <ShellContent Route="ProfilePage" ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
    </TabBar>

</Shell>