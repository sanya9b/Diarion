    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET MAUI",
            "type": "maui",
            "request": "launch",
            "preLaunchTask": "maui: Build"
        },
        {
            "name": "iOS Release Publish",
            "type": "node-terminal",
            "request": "launch",
            "command": "dotnet publish Diarion.csproj -f net10.0-ios -c Release -p:RuntimeIdentifier=ios-arm64 -p:BuildIpa=true -p:CodesignKey=- -p:CodesignProvision=- -v minimal"
        }
    ]
}