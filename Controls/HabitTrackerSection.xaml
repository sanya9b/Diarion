<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:viewmodels="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             x:Class="Diarion.Controls.HabitTrackerSection"
             x:Name="HabitTrackerSectionRoot">

    <Border StrokeShape="RoundRectangle 16"
            StrokeThickness="1"
            Stroke="{DynamicResource Theme_Dust_Ocean}"
            BackgroundColor="{DynamicResource Theme_Snow_Black}"
            Padding="16">
        <VerticalStackLayout Spacing="8">
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                <Label Grid.Column="0" Text="{x:Static localization:AppResources.HabitsLabel}" FontAttributes="Bold" FontSize="11" CharacterSpacing="1.5" TextTransform="Uppercase" TextColor="{DynamicResource Theme_Midnight_Snow}" VerticalOptions="Center" />
                <Grid Grid.Column="1" Padding="8,4" BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BindingContext.HabitsSection.ToggleEditHabitsModeCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" />
                    </Grid.GestureRecognizers>
                    <Label Text="✎" FontSize="14" InputTransparent="True" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                </Grid>
            </Grid>
            
            <FlexLayout BindableLayout.ItemsSource="{Binding Habits}" Wrap="Wrap" Direction="Row" JustifyContent="SpaceBetween">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:HabitItemViewModel">
                        <ContentView FlexLayout.Basis="48%">
                            <ContentView.GestureRecognizers>
                                <DragGestureRecognizer CanDrag="{Binding BindingContext.HabitsSection.IsEditHabitsMode, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       DragStartingCommand="{Binding BindingContext.HabitsSection.DragHabitStartingCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       DragStartingCommandParameter="{Binding .}"
                                                       DropCompletedCommand="{Binding BindingContext.HabitsSection.DropHabitCompletedCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" />
                                <DropGestureRecognizer AllowDrop="{Binding BindingContext.HabitsSection.IsEditHabitsMode, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       DropCommand="{Binding BindingContext.HabitsSection.ReorderHabitsCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       DropCommandParameter="{Binding .}" />
                            </ContentView.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8" HeightRequest="32">
                                <controls:RoundedCheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}" VerticalOptions="Center" Color="{DynamicResource Theme_Coral}" />
                                <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" FontSize="12" LineBreakMode="TailTruncation" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                                
                                <Grid Grid.Column="2"
                                      WidthRequest="20" HeightRequest="20"
                                      VerticalOptions="Center"
                                      BackgroundColor="Transparent"
                                      IsVisible="{Binding BindingContext.HabitsSection.IsEditHabitsMode, Source={RelativeSource AncestorType={x:Type ContentPage}}}">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.HabitsSection.DeleteHabitCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="✖" FontSize="12" InputTransparent="True" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{DynamicResource Theme_Coral}" />
                                </Grid>
                            </Grid>
                        </ContentView>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
            
            <Label Text="{x:Static localization:AppResources.AddHabitLabel}"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextTransform="Uppercase"
                   TextColor="{DynamicResource Theme_Ocean_Dust}"
                   HorizontalOptions="Start"
                   Padding="0,4">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding BindingContext.HabitsSection.AddHabitCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" />
                </Label.GestureRecognizers>
            </Label>
        </VerticalStackLayout>
    </Border>

</ContentView>