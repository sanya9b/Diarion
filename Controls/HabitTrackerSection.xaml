<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             x:Class="Diarion.Controls.HabitTrackerSection"
             x:Name="HabitTrackerSectionRoot">

    <Border StrokeShape="RoundRectangle 16"
            StrokeThickness="1"
            Stroke="{DynamicResource Theme_Dust_Ocean}"
            BackgroundColor="{DynamicResource Theme_Snow_Black}"
            Padding="16">
        <Border.Shadow>
            <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,4" Radius="8" Opacity="0.1" />
        </Border.Shadow>
        <VerticalStackLayout Spacing="8">
            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                <Label Grid.Column="0" Text="{x:Static localization:AppResources.HabitsLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Ocean_Dust}" VerticalOptions="Center" />
                <Grid Grid.Column="1" Padding="10,4" BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BindingContext.ToggleEditHabitsModeCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" />
                    </Grid.GestureRecognizers>
                    <Label Text="✎" FontSize="16" InputTransparent="True" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                </Grid>
            </Grid>
            
            <FlexLayout BindableLayout.ItemsSource="{Binding Habits}" Wrap="Wrap" Direction="Row" JustifyContent="SpaceBetween">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:HabitItem">
                        <ContentView FlexLayout.Basis="48%">
                            <ContentView.GestureRecognizers>
                                <DragGestureRecognizer CanDrag="{Binding BindingContext.IsEditHabitsMode, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       DragStartingCommand="{Binding BindingContext.DragHabitStartingCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       DragStartingCommandParameter="{Binding .}"
                                                       DropCompletedCommand="{Binding BindingContext.DropHabitCompletedCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" />
                                <DropGestureRecognizer AllowDrop="{Binding BindingContext.IsEditHabitsMode, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       DropCommand="{Binding BindingContext.ReorderHabitsCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                       DropCommandParameter="{Binding .}" />
                            </ContentView.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="6" HeightRequest="36">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}" VerticalOptions="Center" Scale="0.8" Margin="-8,0,-4,0" />
                                <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" FontSize="12" LineBreakMode="TailTruncation" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                                
                                <Grid Grid.Column="2" 
                                      WidthRequest="20" HeightRequest="20" 
                                      VerticalOptions="Center" 
                                      BackgroundColor="Transparent"
                                      IsVisible="{Binding BindingContext.IsEditHabitsMode, Source={RelativeSource AncestorType={x:Type ContentPage}}}">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.DeleteHabitCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="✖" FontSize="12" InputTransparent="True" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{DynamicResource Theme_Coral}" />
                                </Grid>
                            </Grid>
                        </ContentView>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
            
            <Button Text="{x:Static localization:AppResources.AddHabitLabel}"
                    Command="{Binding BindingContext.AddHabitCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                    BackgroundColor="Transparent"
                    TextColor="{DynamicResource Theme_Ocean_Dust}"
                    FontAttributes="Bold"
                    HorizontalOptions="Start"
                    Padding="0,8" />
        </VerticalStackLayout>
    </Border>

</ContentView>