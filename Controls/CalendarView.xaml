<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Diarion.Controls.CalendarView"
             x:Name="CalendarViewRoot">

    <Grid x:Name="CalendarSection" RowDefinitions="Auto, Auto" IsClippedToBounds="True">
        <Grid x:Name="CalendarHeader" Grid.Row="0" RowDefinitions="Auto, Auto">
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,4,0,12">
                <Grid Grid.Column="0" BackgroundColor="Transparent" Padding="20,10" VerticalOptions="Center" HorizontalOptions="Start">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PreviousMonthCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Text="&lt;" FontSize="32" InputTransparent="True" FontAttributes="Bold" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                </Grid>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="-10">
                    <Label Text="{Binding CurrentMonthName}" FontFamily="MarckScript" FontSize="40" TextColor="{DynamicResource Theme_Midnight_Snow}" HorizontalOptions="Center" />
                    <Label Text="{Binding CurrentYear}" FontSize="14" TextColor="{DynamicResource Theme_Ocean_Dust}" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Grid Grid.Column="2" BackgroundColor="Transparent" Padding="20,10" VerticalOptions="Center" HorizontalOptions="End">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Text="&gt;" FontSize="32" InputTransparent="True" FontAttributes="Bold" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                </Grid>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Margin="0,0,0,8">
                <Label Grid.Column="0" Text="{x:Static localization:AppResources.WeekdayMonShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <Label Grid.Column="1" Text="{x:Static localization:AppResources.WeekdayTueShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <Label Grid.Column="2" Text="{x:Static localization:AppResources.WeekdayWedShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <Label Grid.Column="3" Text="{x:Static localization:AppResources.WeekdayThuShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <Label Grid.Column="4" Text="{x:Static localization:AppResources.WeekdayFriShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <Label Grid.Column="5" Text="{x:Static localization:AppResources.WeekdaySatShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <Label Grid.Column="6" Text="{x:Static localization:AppResources.WeekdaySunShort}" FontSize="11" HorizontalTextAlignment="Center" TextColor="{DynamicResource Theme_Ocean_Dust}" />
            </Grid>
        </Grid>

        <FlexLayout Grid.Row="1" x:Name="CalendarGrid" BindableLayout.ItemsSource="{Binding CalendarDays}"
                Wrap="Wrap"
                Direction="Row"
                JustifyContent="SpaceBetween"
                AlignContent="Start">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="models:CalendarDay">
                    <ContentView FlexLayout.Basis="13.5%" HeightRequest="52" Margin="0,0,0,8">
                        <Grid>
                            <Border StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    BackgroundColor="{DynamicResource Theme_Snow}"
                                    Padding="6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.SelectDateCommand, Source={x:Reference CalendarViewRoot}}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsPredictedCycleDay}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Theme_BerryTransparent}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsCycleDay}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Theme_BerryTransparent}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="StrokeThickness" Value="1.5" />
                                    <Setter Property="Stroke" Value="{DynamicResource Theme_Midnight_Snow}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Theme_Midnight_Snow}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid>
                                <!-- Day Number (Top Left) -->
                                <Label Text="{Binding Day}" HorizontalOptions="Start" VerticalOptions="Start" FontSize="13" InputTransparent="True" TextColor="{DynamicResource Theme_Midnight_Snow}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCurrentMonth}" Value="False">
                                            <Setter Property="Opacity" Value="0.25" />
                                    </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="TextColor" Value="{DynamicResource Theme_Snow_Midnight}" />
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                
                                <!-- Pacifier icon for fertile window (Bottom Left) -->
                                <Image Source="pacifier.png" WidthRequest="16" HeightRequest="16" HorizontalOptions="Start" VerticalOptions="End" Aspect="AspectFit" InputTransparent="True" IsVisible="{Binding IsFertileWindow}" Margin="-2,0,0,-2">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="{DynamicResource Theme_Berry}" />
                                    </Image.Behaviors>
                                </Image>

                                <!-- Priority Task Dot (Bottom Right) -->
                                <Ellipse Fill="{Binding PriorityDotColor}" WidthRequest="6" HeightRequest="6" HorizontalOptions="End" VerticalOptions="End" IsVisible="{Binding HasTasks}" InputTransparent="True" />
                            </Grid>
                        </Border>
                        
                        <!-- Progress Border Overlay OUTSIDE the clipping mask -->
                        <controls:ProgressBorder Progress="{Binding TaskCompletionPercentage}" 
                                                 StrokeColor="{Binding ProgressColor}"
                                                 CornerRadius="8"
                                                 InputTransparent="True" />
                        </Grid>
                    </ContentView>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </FlexLayout>
    </Grid>

</ContentView>