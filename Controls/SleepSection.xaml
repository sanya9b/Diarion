<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Diarion.Models;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             x:Class="Diarion.Controls.SleepSection"
             x:DataType="models:DiaryEntry">
    
    <Border StrokeShape="RoundRectangle 16"
            StrokeThickness="1"
            Stroke="{DynamicResource Theme_Dust_Ocean}"
            BackgroundColor="{DynamicResource Theme_Snow_Black}"
            Padding="16">
        <Border.Shadow>
            <Shadow Brush="{DynamicResource Theme_Midnight}" Offset="0,4" Radius="8" Opacity="0.1" />
        </Border.Shadow>
        <VerticalStackLayout Spacing="8">
            <Label Text="{x:Static localization:AppResources.SleepLabel}" FontAttributes="Bold" FontSize="12" CharacterSpacing="1.5" TextColor="{DynamicResource Theme_Ocean_Dust}" />
            <Grid ColumnDefinitions="Auto, *, Auto, *" ColumnSpacing="12" Margin="0,4">
                <Label Grid.Column="0" Text="{x:Static localization:AppResources.SleepEndLabel}" VerticalOptions="Center" FontSize="12" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                <Border Grid.Column="1" StrokeThickness="1" Stroke="{DynamicResource Theme_Dust_Ocean}" BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" HeightRequest="36">
                    <Grid>
                        <Label Text="{Binding SleepEnd, StringFormat='{0:hh\\:mm}'}" 
                               IsVisible="{Binding HasSleepEnd}"
                               TextColor="{DynamicResource Theme_Midnight_Snow}" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Label Text="HH:mm" 
                               IsVisible="{Binding IsSleepEndEmpty}"
                               TextColor="{DynamicResource Theme_Ocean_Dust}" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                        <TimePicker Time="{Binding SleepEnd, TargetNullValue='00:00', FallbackValue='00:00'}" Format="HH:mm"
                                    TextColor="Transparent" BackgroundColor="Transparent" />
                    </Grid>
                </Border>

                <Label Grid.Column="2" Text="{x:Static localization:AppResources.SleepStartLabel}" VerticalOptions="Center" FontSize="12" TextColor="{DynamicResource Theme_Midnight_Snow}" Margin="4,0,0,0" />
                <Border Grid.Column="3" StrokeThickness="1" Stroke="{DynamicResource Theme_Dust_Ocean}" BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" HeightRequest="36">
                    <Grid>
                        <Label Text="{Binding SleepStart, StringFormat='{0:hh\\:mm}'}" 
                               IsVisible="{Binding HasSleepStart}"
                               TextColor="{DynamicResource Theme_Midnight_Snow}" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Label Text="HH:mm" 
                               IsVisible="{Binding IsSleepStartEmpty}"
                               TextColor="{DynamicResource Theme_Ocean_Dust}" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                        <TimePicker Time="{Binding SleepStart, TargetNullValue='00:00', FallbackValue='00:00'}" Format="HH:mm"
                                    TextColor="Transparent" BackgroundColor="Transparent" />
                    </Grid>
                </Border>
            </Grid>
            <Grid ColumnDefinitions="110, *" ColumnSpacing="12">
                <Label Grid.Column="0" Text="{x:Static localization:AppResources.SleepQualityLabel}" VerticalOptions="Center" FontSize="12" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                <controls:RatingView Grid.Column="1" Value="{Binding SleepQuality}" MaxValue="5" VerticalOptions="Center" HorizontalOptions="Start" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>