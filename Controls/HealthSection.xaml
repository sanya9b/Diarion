<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vms="clr-namespace:Diarion.ViewModels;assembly=Diarion.Core"
             xmlns:localization="clr-namespace:Diarion.Resources.Localization;assembly=Diarion.Core"
             xmlns:controls="clr-namespace:Diarion.Controls"
             x:Class="Diarion.Controls.HealthSection"
             x:DataType="vms:DiaryEntryViewModel">
    
    <Border StrokeShape="RoundRectangle 16"
            StrokeThickness="1"
            Stroke="{DynamicResource Theme_Dust_Ocean}"
            BackgroundColor="{DynamicResource Theme_Snow_Black}"
            Padding="16">
        <VerticalStackLayout Spacing="10">
            <Label Text="{x:Static localization:AppResources.HealthLabel}" FontAttributes="Bold" FontSize="11" CharacterSpacing="1.5" TextTransform="Uppercase" TextColor="{DynamicResource Theme_Midnight_Snow}" Margin="0,0,0,4" />
            
            <Grid ColumnDefinitions="100, *" ColumnSpacing="12" IsVisible="{Binding BindingContext.CycleStatusSection.IsVisible, Source={RelativeSource AncestorType={x:Type ContentPage}}}">
                <Label Grid.Column="0" Text="{x:Static localization:AppResources.CycleDayLabel}" VerticalOptions="Center" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                    <Label Text="{Binding BindingContext.CycleStatusSection.CycleDayText, Source={RelativeSource AncestorType={x:Type ContentPage}}}" FontAttributes="Bold" FontSize="13" TextColor="{DynamicResource Theme_Midnight_Snow}" />
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="{x:Static localization:AppResources.PregnancyProbabilityLabel}" FontSize="11" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                        <Label Text="{Binding BindingContext.CycleStatusSection.PregnancyProbabilityText, Source={RelativeSource AncestorType={x:Type ContentPage}}}" FontSize="11" FontAttributes="Bold" TextColor="{Binding BindingContext.CycleStatusSection.PregnancyProbabilityColor, Source={RelativeSource AncestorType={x:Type ContentPage}}}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="100, *" ColumnSpacing="12">
                <Label Grid.Column="0" Text="{x:Static localization:AppResources.HealthStatusLabel}" VerticalOptions="Center" FontSize="12" FontAttributes="Bold" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <controls:RatingView Grid.Column="1" Value="{Binding HealthStatus}" MaxValue="5" VerticalOptions="Center" HorizontalOptions="Start" />
            </Grid>

            <Grid ColumnDefinitions="Auto, 100, *" ColumnSpacing="12">
                <controls:RoundedCheckBox Grid.Column="0" IsChecked="{Binding IsIntimateLifeDone}" VerticalOptions="Center" Color="{DynamicResource Theme_Coral}" />
                <Label Grid.Column="1" Text="{x:Static localization:AppResources.IntimateLifeLabel}" VerticalOptions="Center" FontSize="12" TextColor="{DynamicResource Theme_Ocean_Dust}" />
                <Border Grid.Column="2" StrokeThickness="1" Stroke="{DynamicResource Theme_Dust_Ocean}" BackgroundColor="Transparent" StrokeShape="RoundRectangle 12" HeightRequest="36" Padding="12,0">
                    <Entry Text="{Binding IntimateLife}" BackgroundColor="Transparent" TextColor="{DynamicResource Theme_Midnight_Snow}" FontSize="13" VerticalOptions="Center" />
                </Border>
            </Grid>
        </VerticalStackLayout>
    </Border>
</ContentView>